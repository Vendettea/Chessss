@using Chessss.Models
@using Chessss.Data
@using Chessss.Services
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using System.IO
@inject ApplicationDbContext Db
@inject ISnackbar Snackbar
@inject UploadStorageService UploadStorage

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h5" Class="mb-6">@(Material?.Id == 0 ? "Создать новый материал" : "Редактировать материал")</MudText>

        <MudTextField @bind-Value="Material.Title" 
                      Label="Название" 
                      FullWidth 
                      Class="mb-4"
                      Variant="Variant.Outlined" />

        <MudTextField @bind-Value="Material.Description" 
                      Label="Описание" 
                      FullWidth 
                      Class="mb-4"
                      Lines="3"
                      Variant="Variant.Outlined" />

        <MudTextField @bind-Value="Material.Content" 
                      Label="Содержание (текст урока)" 
                      FullWidth 
                      Class="mb-4"
                      Lines="6"
                      Variant="Variant.Outlined" />

        <MudTextField @bind-Value="Material.FenPosition" 
                      Label="FEN позиция (если есть)" 
                      FullWidth 
                      Class="mb-4"
                      Variant="Variant.Outlined" />

        <MudText Typo="Typo.subtitle2" Class="mb-2">Изображение</MudText>
        <div style="display: flex; gap: 12px; align-items: flex-end; margin-bottom: 16px;">
            <InputFile OnChange="UploadImage" accept=".jpg,.jpeg,.png,.gif,.webp" />
            <MudButton Variant="Variant.Outlined" 
                       Color="Color.Info"
                       StartIcon="@Icons.Material.Filled.FileUpload">
                Выбрать файл
            </MudButton>
        </div>

        @if (!string.IsNullOrEmpty(Material.ImageUrl))
        {
            <div style="border: 1px solid #e0e0e0; padding: 12px; border-radius: 4px; margin-bottom: 16px;">
                <MudText Typo="Typo.caption" Class="mb-2">Предпросмотр:</MudText>
                <img src="@Material.ImageUrl" style="max-width: 100%; max-height: 200px; border-radius: 4px;" alt="Превью" />
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Error" 
                           Size="Size.Small" 
                           Class="mt-2"
                           OnClick="RemoveImage">
                    Удалить изображение
                </MudButton>
            </div>
        }

        <MudText Typo="Typo.subtitle2" Class="mb-3">Теги</MudText>
        <MudSelect T="string" 
                   MultiSelection="true" 
                   SelectedValuesChanged="OnTagsChanged"
                   Variant="Variant.Outlined"
                   FullWidth
                   Placeholder="Выберите теги">
            @foreach (var tag in _allTags)
            {
                <MudSelectItem T="string" Value="@tag.Name">@tag.Name</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Отмена</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Сохранить</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public TrainingMaterial Material { get; set; } = new();

    private List<Tag> _allTags = new();
    private HashSet<string> _selectedTags = new();

    protected override async Task OnInitializedAsync()
    {
        _allTags = await Db.Tags.ToListAsync();
        
        if (Material.Id != 0 && Material.Tags != null)
        {
            _selectedTags = new HashSet<string>(Material.Tags.Select(t => t.Name));
        }
    }

    private void OnTagsChanged(IEnumerable<string> selectedValues)
    {
        _selectedTags = new HashSet<string>(selectedValues ?? new List<string>());
        Material.Tags = _allTags.Where(t => _selectedTags.Contains(t.Name)).ToList();
    }

    private async Task Save()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(Material.Title))
            {
                Snackbar.Add("Название не может быть пустым", Severity.Error);
                return;
            }

            if (Material.Id == 0)
            {
                Db.TrainingMaterials.Add(Material);
            }
            else
            {
                Db.TrainingMaterials.Update(Material);
            }

            await Db.SaveChangesAsync();
            Snackbar.Add("Материал сохранен", Severity.Success);
            MudDialog.Close(DialogResult.Ok(Material));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка при сохранении: {ex.Message}", Severity.Error);
        }
    }

    private async Task UploadImage(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        // Проверяем размер (макс 5MB)
        if (file.Size > 5 * 1024 * 1024)
        {
            Snackbar.Add("Файл слишком большой (макс 5MB)", Severity.Error);
            return;
        }

        // Проверяем тип
        var allowedTypes = new[] { "image/jpeg", "image/png", "image/gif", "image/webp" };
        if (!allowedTypes.Contains(file.ContentType))
        {
            Snackbar.Add("Неподдерживаемый тип файла", Severity.Error);
            return;
        }

        // Генерируем уникальное имя
        var extension = Path.GetExtension(file.Name);
        var fileName = $"{Guid.NewGuid()}{extension}";
        var path = Path.Combine(UploadStorage.GetUploadsDirectory(), fileName);

        // Сохраняем файл
        await using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
        await using var fileStream = new FileStream(path, FileMode.Create);
        await stream.CopyToAsync(fileStream);

        // Удаляем старый файл, если есть
        if (!string.IsNullOrEmpty(Material.ImageUrl) && Material.ImageUrl.StartsWith("/uploads/"))
        {
            var oldPath = UploadStorage.ResolvePhysicalPath(Material.ImageUrl);
            if (!string.IsNullOrWhiteSpace(oldPath) && System.IO.File.Exists(oldPath))
            {
                System.IO.File.Delete(oldPath);
            }
        }

        // Устанавливаем новый URL
        Material.ImageUrl = $"/uploads/{fileName}";
        Snackbar.Add("Изображение загружено", Severity.Success);
        StateHasChanged();
    }

    private void RemoveImage()
    {
        if (!string.IsNullOrEmpty(Material.ImageUrl) && Material.ImageUrl.StartsWith("/uploads/"))
        {
            var path = UploadStorage.ResolvePhysicalPath(Material.ImageUrl);
            if (!string.IsNullOrWhiteSpace(path) && System.IO.File.Exists(path))
            {
                System.IO.File.Delete(path);
            }
        }
        Material.ImageUrl = null;
        Snackbar.Add("Изображение удалено", Severity.Success);
        StateHasChanged();
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
