@page "/training"
@rendermode InteractiveServer
@using Chessss.Components.Admin
@using Chessss.Data
@using Chessss.Models
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@inject ApplicationDbContext Db
@inject IDialogService DialogService

<PageTitle>UltraChess - Гайды</PageTitle>

<div class="page-shell training-page">
    <MudPaper Class="form-panel app-card mb-4" Elevation="0">
        <MudTextField T="string"
                      Placeholder="Поиск по названию..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium"
                      Class="mb-4"
                      ValueChanged="OnSearchChanged"
                      Immediate="true" />

        <MudSelect T="string" MultiSelection="true" Label="Фильтр по тегам" SelectedValuesChanged="OnTagsSelected" Variant="Variant.Outlined">
            @foreach (var tag in _allTagNames)
            {
                <MudSelectItem T="string" Value="@tag">@tag</MudSelectItem>
            }
        </MudSelect>
    </MudPaper>

    <div class="training-list">
        @foreach (var material in _filteredMaterials)
        {
            <MudCard Elevation="0" Class="training-card app-card training-list__item">
                <div class="training-list__media training-card-image">
                    @if (!string.IsNullOrEmpty(material.ImageUrl))
                    {
                        <img src="@material.ImageUrl"
                             class="training-list__image"
                             alt="@material.Title"
                             onload="this.style.display='block'; this.parentElement.querySelector('.fallback-icon').style.display='none';"
                             onerror="this.style.display='none'; this.parentElement.querySelector('.fallback-icon').style.display='flex';" />
                        <MudIcon Icon="@Icons.Material.Filled.School" Class="fallback-icon training-list__fallback" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.School" Class="fallback-icon training-list__fallback training-list__fallback--visible" />
                    }
                    <div class="training-list__overlay"></div>
                </div>

                <div class="training-list__body">
                    <div>
                        <MudText Typo="Typo.h6" Class="mb-2 training-list__title">@material.Title</MudText>

                        <div class="mb-3">
                            @foreach (var tag in material.Tags)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Class="mr-1 mb-1">@tag.Name</MudChip>
                            }
                        </div>

                        <MudText Typo="Typo.body2" Class="text-truncate-3 training-list__description">@material.Description</MudText>
                    </div>

                    <div class="training-list__actions">
                        <MudButton Variant="Variant.Filled" Color="Color.Success" Href="@($"/training/{material.Id}")" Size="Size.Small">
                            Изучить гайд
                        </MudButton>
                    </div>
                </div>
            </MudCard>
        }
    </div>
</div>

<style>
    .training-page {
        padding-block: 1rem 1.5rem;
    }

    .training-list {
        display: grid;
        gap: 1rem;
    }

    .training-list__item {
        display: grid;
        grid-template-columns: minmax(14rem, 18rem) minmax(0, 1fr);
        overflow: hidden;
    }

    .training-list__media {
        min-height: 14rem;
        background: linear-gradient(135deg, color-mix(in srgb, var(--app-accent-2) 70%, #23334d), color-mix(in srgb, var(--app-accent) 80%, #182235));
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .training-list__image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .training-list__fallback {
        font-size: 4rem;
        color: white;
        opacity: 0.85;
        position: absolute;
        z-index: 2;
        display: none;
    }

    .training-list__fallback--visible {
        display: flex;
    }

    .training-list__overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.12);
    }

    .training-list__body {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.2rem;
    }

    .training-list__title {
        font-weight: 700;
    }

    .training-list__description {
        color: var(--app-muted);
    }

    .training-list__actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    @@media (max-width: 860px) {
        .training-list__item {
            grid-template-columns: 1fr;
        }

        .training-list__media {
            min-height: 12rem;
        }
    }
</style>

@code {
    private string _searchString = "";
    private IEnumerable<string> _selectedTagNames = new HashSet<string>();

    private List<string> _allTagNames = new();
    private List<TrainingMaterial> _allMaterials = new();
    private List<TrainingMaterial> _filteredMaterials = new();

    protected override async Task OnInitializedAsync()
    {
        _allMaterials = await Db.TrainingMaterials.Include(x => x.Tags).ToListAsync();
        _allTagNames = await Db.Tags.Select(t => t.Name).ToListAsync();
        _filteredMaterials = _allMaterials;
    }

    private void OnSearchChanged(string text)
    {
        _searchString = text;
        ApplyFilters();
    }

    private void OnTagsSelected(IEnumerable<string> selectedValues)
    {
        _selectedTagNames = selectedValues;
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        var query = _allMaterials.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchString))
        {
            query = query.Where(m => m.Title.Contains(_searchString, StringComparison.OrdinalIgnoreCase));
        }

        if (_selectedTagNames != null && _selectedTagNames.Any())
        {
            query = query.Where(m => m.Tags.Any(t => _selectedTagNames.Contains(t.Name)));
        }

        _filteredMaterials = query.ToList();
    }

    private async Task RefreshMaterials()
    {
        _allMaterials = await Db.TrainingMaterials.Include(x => x.Tags).ToListAsync();
        _filteredMaterials = _allMaterials;
        StateHasChanged();
    }
}
