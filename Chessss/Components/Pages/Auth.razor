@page "/auth"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components

<div class="d-flex align-center justify-center" style="min-height: 80vh;">
    <MudContainer MaxWidth="MaxWidth.Small">
        <MudPaper Elevation="4"
                  Class="pa-8"
                  Style="@($"border-radius: 20px; background-color: {(IsDarkMode ? "#1e1e1e" : "#ffffff")};")">

            <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6 fw-bold" Style="color: white !important;">Вход</MudText>

            @if (!string.IsNullOrEmpty(SuccessMessage))
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">@SuccessMessage</MudAlert>
            }

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@ErrorMessage</MudAlert>
            }

            <form method="post" action="/auth/login">
                <AntiforgeryToken />

                <MudTextField @bind-Value="LoginModel.Email"
                              Label="Email"
                              name="email"
                              Variant="Variant.Filled"
                              InputType="InputType.Email"
                              Required="true"
                              RequiredError="Введите почту"
                              Class="mb-4" />

                <MudTextField @bind-Value="LoginModel.Password"
                              Label="Пароль"
                              name="password"
                              Variant="Variant.Filled"
                              InputType="InputType.Password"
                              Required="true"
                              RequiredError="Введите пароль"
                              Class="mb-4" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Success"
                           FullWidth="true"
                           Style="height: 50px; border-radius: 10px;"
                           Class="mt-4">
                    Войти
                </MudButton>

                <div class="d-flex justify-center mt-4">
                    <MudText Typo="Typo.body2"
                             Class="mr-1"
                             Style="@($"color: {(IsDarkMode ? "#aaa" : "#666")}")">
                        Нет аккаунта?
                    </MudText>
                    <MudLink Href="/regis"
                             Underline="Underline.Hover"
                             Color="Color.Success"
                             Typo="Typo.body2"
                             Class="fw-bold">
                        Зарегистрироваться
                    </MudLink>
                </div>
            </form>
        </MudPaper>
    </MudContainer>
</div>

@code {
    [CascadingParameter]
    public bool IsDarkMode { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "registered")]
    public string? Registered { get; set; }

    [SupplyParameterFromQuery(Name = "loggedOut")]
    public string? LoggedOut { get; set; }

    public LoginInput LoginModel { get; set; } = new();

    private string? ErrorMessage => Error switch
    {
        "missing" => "Введите email и пароль.",
        "invalid" => "Неверный email или пароль.",
        "locked" => "Аккаунт временно заблокирован. Попробуйте позже.",
        "notallowed" => "Вход пока недоступен. Возможно, нужно подтвердить email.",
        "form" => "Форма устарела. Обновите страницу и попробуйте снова.",
        _ => null
    };

    private string? SuccessMessage
    {
        get
        {
            if (Registered == "1")
            {
                return "Регистрация прошла успешно. Теперь войдите в аккаунт.";
            }

            if (LoggedOut == "1")
            {
                return "Вы вышли из аккаунта.";
            }

            return null;
        }
    }

    public class LoginInput
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        public string Password { get; set; } = "";
    }
}
