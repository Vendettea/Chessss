@page "/auth"
@using Microsoft.AspNetCore.Identity
@using Chessss.Models
@using System.ComponentModel.DataAnnotations
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="4" Class="pa-8" Style="border-radius: 20px;">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6">Вход</MudText>

        @* Важно: указываем FormName, чтобы Blazor понял, какую форму обрабатывать *@
        <EditForm Model="LoginModel" OnValidSubmit="HandleLogin" FormName="LoginForm" method="post">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="LoginModel.Email"
                          Label="Email"
                          name="LoginModel.Email"
                          Variant="Variant.Filled"
                          Class="mb-4" />

            <MudTextField @bind-Value="LoginModel.Password"
                          Label="Пароль"
                          name="LoginModel.Password"
                          Variant="Variant.Filled"
                          InputType="InputType.Password"
                          Class="mb-4" />

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudText Color="Color.Error" Class="mb-4">@_error</MudText>
            }

            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Success" FullWidth="true">
                Войти
            </MudButton>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromForm]
    public LoginInput LoginModel { get; set; } = new();

    private string? _error;

    public class LoginInput
    {
        [Required] public string Email { get; set; } = "";
        [Required] public string Password { get; set; } = "";
    }

    private async Task HandleLogin()
    {
        // Теперь это работает как в твоем проекте с доставкой
        var result = await SignInManager.PasswordSignInAsync(LoginModel.Email, LoginModel.Password, isPersistent: true, lockoutOnFailure: false);

        if (result.Succeeded)
        {
            // forceLoad: true ОБЯЗАТЕЛЕН, чтобы браузер «проснулся» с новой кукой
            Nav.NavigateTo("/", forceLoad: true);
        }
        else
        {
            _error = "Ошибка входа. Проверьте данные.";
        }
    }
}