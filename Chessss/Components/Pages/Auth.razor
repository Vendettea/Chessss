@page "/auth"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components

<div class="page-shell auth-page">
    <MudContainer MaxWidth="MaxWidth.Small">
        <MudPaper Elevation="0" Class="form-panel auth-card">
            <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-4 fw-bold">Вход</MudText>
            <MudText Typo="Typo.body2" Align="Align.Center" Class="auth-muted mb-6">Войдите в UltraChess, чтобы сохранять партии, рейтинг и профиль.</MudText>

            @if (!string.IsNullOrEmpty(SuccessMessage))
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">@SuccessMessage</MudAlert>
            }

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@ErrorMessage</MudAlert>
            }

            <form method="post" action="/auth/login">
                <AntiforgeryToken />

                <MudTextField @bind-Value="LoginModel.Email"
                              Label="Email"
                              name="email"
                              Variant="Variant.Outlined"
                              InputType="InputType.Email"
                              Required="true"
                              RequiredError="Введите почту"
                              Class="mb-4" />

                <MudTextField @bind-Value="LoginModel.Password"
                              Label="Пароль"
                              name="password"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Required="true"
                              RequiredError="Введите пароль"
                              Class="mb-4" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Success"
                           FullWidth="true"
                           Class="auth-submit">
                    Войти
                </MudButton>

                <div class="auth-footer">
                    <MudText Typo="Typo.body2" Class="auth-muted">Нет аккаунта?</MudText>
                    <MudLink Href="/regis" Underline="Underline.Hover" Color="Color.Success" Typo="Typo.body2" Class="fw-bold">
                        Зарегистрироваться
                    </MudLink>
                </div>
            </form>
        </MudPaper>
    </MudContainer>
</div>

<style>
    .auth-page {
        min-height: calc(100dvh - 2rem);
        display: flex;
        align-items: center;
        justify-content: center;
        padding-block: 1rem 2rem;
    }

    .auth-card {
        max-width: 32rem;
        margin-inline: auto;
    }

    .auth-submit {
        min-height: 3.25rem;
        border-radius: 1rem;
    }

    .auth-footer {
        display: flex;
        justify-content: center;
        gap: 0.4rem;
        flex-wrap: wrap;
        margin-top: 1rem;
    }

    .auth-muted {
        color: var(--app-muted);
    }
</style>

@code {
    [CascadingParameter]
    public bool IsDarkMode { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "registered")]
    public string? Registered { get; set; }

    [SupplyParameterFromQuery(Name = "loggedOut")]
    public string? LoggedOut { get; set; }

    public LoginInput LoginModel { get; set; } = new();

    private string? ErrorMessage => Error switch
    {
        "missing" => "Введите email и пароль.",
        "invalid" => "Неверный email или пароль.",
        "locked" => "Аккаунт временно заблокирован. Попробуйте позже.",
        "notallowed" => "Вход пока недоступен. Возможно, нужно подтвердить email.",
        "form" => "Форма устарела. Обновите страницу и попробуйте снова.",
        _ => null
    };

    private string? SuccessMessage
    {
        get
        {
            if (Registered == "1")
            {
                return "Регистрация прошла успешно. Теперь войдите в аккаунт.";
            }

            if (LoggedOut == "1")
            {
                return "Вы вышли из аккаунта.";
            }

            return null;
        }
    }

    public class LoginInput
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        public string Password { get; set; } = "";
    }
}
