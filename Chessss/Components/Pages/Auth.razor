@page "/auth"
@using MudBlazor
@using Chessss.Data
@using Chessss.Models
@using Microsoft.EntityFrameworkCore

@rendermode InteractiveServer

@inject ApplicationDbContext DbContext
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>UltraChess - Authorization</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="height: 80vh;">
    <MudPaper Elevation="4" Class="pa-8" 
              Style="@($"width: 100%; background-color: {(IsDarkMode ? "#1a1a1a" : "#ffffff")}; color: {(IsDarkMode ? "#ffffff" : "#212121")}; border-radius: 20px; transition: 0.3s;")">
        
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6 fw-bold">Вход</MudText>
        
        <MudTextField @bind-Value="_email" T="string" Label="Email" Variant="Variant.Filled" Class="mb-4" />
        <MudTextField @bind-Value="_password" T="string" Label="Пароль" Variant="Variant.Filled" InputType="InputType.Password" />
        
        <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" Class="mt-6 py-3" OnClick="HandleLogin">
            Войти
        </MudButton>
        
        <div class="d-flex justify-center mt-4">
            <MudText Typo="Typo.body2" Class="mr-1" Style="@($"color: {(IsDarkMode ? "#aaa" : "#666")}")">Нет аккаунта?</MudText>
            <MudLink Href="/regis" Underline="Underline.Hover" Color="Color.Success" Typo="Typo.body2" Class="fw-bold">Зарегистрироваться</MudLink>
        </div>
    </MudPaper>
</MudContainer>

@code {
    [CascadingParameter] public bool IsDarkMode { get; set; }
    
    private string _email;
    private string _password;

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            Snackbar.Add("Введите email и пароль", Severity.Warning);
            return;
        }

        try 
        {
            // Ищем пользователя с таким Email и Паролем
            var user = await DbContext.Users
                .FirstOrDefaultAsync(u => u.Email == _email && u.PasswordHash == _password);

            if (user != null)
            {
                Snackbar.Add($"Добро пожаловать, {user.Email}!", Severity.Success);
                
                // Имитация задержки перед переходом
                await Task.Delay(1000);
                Nav.NavigateTo("/"); 
            }
            else
            {
                Snackbar.Add("Неверная почта или пароль", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Ошибка при входе", Severity.Error);
            Console.WriteLine(ex.Message);
        }
    }
}