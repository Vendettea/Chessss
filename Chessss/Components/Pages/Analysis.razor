@page "/analysis"
@page "/analysis/{Id:int}"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.JSInterop
@using Chessss.Models
@using Chessss.Services
@inject IJSRuntime JS
@inject UserManager<ApplicationUser> UserManager
@inject UserGameService UserGameService
@inject ISnackbar Snackbar
@using System.Text.Json
@implements IAsyncDisposable

<PageTitle>UltraChess - Анализ партии</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-4 page-shell">
    <div class="analysis-layout">

        @* ═══ BOARD COLUMN ═══ *@
        <section class="analysis-board-column">
            <div class="analysis-board-area">

                @* Players bar (style ported from PlaywAI.razor, timer removed) *@
                <div class="analysis-players-bar">
                    <div class="analysis-player-block analysis-player-block-start">
                        <MudAvatar Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small" Class="analysis-avatar">
                            <span class="analysis-avatar-glyph">♟</span>
                        </MudAvatar>
                        <div class="analysis-player-copy">
                            <div class="analysis-player-name">@_blackPlayer</div>
                            <div class="analysis-player-subtitle">Чёрные</div>
                        </div>
                    </div>

                    <div class="analysis-player-block analysis-player-block-end">
                        <div class="analysis-player-copy analysis-player-copy-end">
                            <div class="analysis-player-name">@_whitePlayer</div>
                            <div class="analysis-player-subtitle">Белые</div>
                        </div>
                        <MudAvatar Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small" Class="analysis-avatar">
                            <span class="analysis-avatar-glyph">♙</span>
                        </MudAvatar>
                    </div>
                </div>

                <div class="analysis-board-shell">
                    <div id="analysis-board" class="analysis-board"></div>
                </div>

                @* PGN input + combined load-and-analyze action *@
                <div class="pgn-input-row">
                    <MudTextField @bind-Value="PgnInput"
                                  Label="Вставьте PGN партии"
                                  Lines="3"
                                  Variant="Variant.Outlined"
                                  Class="pgn-input-field" />
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="LoadPgnAndAnalyze"
                               Disabled="@(IsAnalyzing || !_boardReady)"
                               Class="pgn-analyze-button">
                        @AnalyzeButtonText
                    </MudButton>
                </div>
            </div>
        </section>

        @* ═══ SIDE COLUMN ═══ *@
        <section class="analysis-side-column">

            @* Tabs: Отчёт / Анализ *@
            <MudPaper Class="chess-side-panel analysis-side-paper" Elevation="0">
                <MudTabs Elevation="0"
                         Rounded="false"
                         ApplyEffectsToContainer="true"
                         Class="analysis-tabs"
                         PanelClass="pa-4">

                    @* ── Отчёт ── *@
                    <MudTabPanel Text="Отчёт">

                        @* Eval chart *@
                        @if (ChartData != null && ChartData.Count > 0)
                        {
                            <MudChart ChartType="ChartType.Line"
                                      ChartSeries="@ChartSeries"
                                      XAxisLabels="@_emptyLabels"
                                      Width="100%"
                                      Height="180px" />
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Class="muted-text mb-4">Запустите анализ для отображения графика.</MudText>
                        }

                        @* Players + accuracy *@
                        <div class="report-summary mt-4 mb-4">
                            <div class="report-player-col">
                                <span class="report-player__name">@_whitePlayer</span>
                                <div class="report-avatar report-avatar--white">Б</div>
                                <span class="accuracy-value">@(_whiteAccuracy?.ToString("0.0") ?? "--")</span>
                            </div>

                            <div class="report-summary__center">
                                <span class="accuracy-divider-label">Accuracy</span>
                            </div>

                            <div class="report-player-col">
                                <span class="report-player__name">@_blackPlayer</span>
                                <div class="report-avatar report-avatar--black">Ч</div>
                                <span class="accuracy-value">@(_blackAccuracy?.ToString("0.0") ?? "--")</span>
                            </div>
                        </div>

                        @* Move quality list (unified, white vs black side by side) *@
                        <div class="mq-list">
                            @foreach (var row in MoveQualityAllRows)
                            {
                                <div class="mq-list-row">
                                    <span class="mq-list-val mq-list-val--left">@MoveQualitiesWhite[row.Key]</span>
                                    <span class="mq-list-label">
                                        <span class="mq-icon" style="color:@row.Color">@row.Icon</span>
                                        @row.Label
                                    </span>
                                    <span class="mq-list-val mq-list-val--right">@MoveQualitiesBlack[row.Key]</span>
                                </div>
                            }
                        </div>

                    </MudTabPanel>

                    @* ── Анализ ── *@
                    <MudTabPanel Text="Анализ">

                        @* Eval score *@
                        <div class="analysis-eval-bar mb-3">
                            <span class="analysis-eval-score">@CurrentEvaluation</span>
                        </div>

                        @* Navigation buttons *@
                        <div class="analysis-nav mb-3">
                            <MudIconButton Icon="@Icons.Material.Filled.FirstPage"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Medium"
                                           OnClick="GoFirst"
                                           Title="В начало" />
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Medium"
                                           OnClick="PrevMove"
                                           Title="Предыдущий ход" />
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Medium"
                                           OnClick="NextMove"
                                           Title="Следующий ход" />
                            <MudIconButton Icon="@Icons.Material.Filled.LastPage"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Medium"
                                           OnClick="GoLast"
                                           Title="В конец" />
                        </div>

                        @* Move list *@
                        <div class="move-list" id="move-list-container">
                            @if (_moveList.Count == 0)
                            {
                                <MudText Typo="Typo.body2" Class="muted-text">Загрузите PGN для отображения ходов.</MudText>
                            }
                            else
                            {
                                @for (int pairIdx = 0; pairIdx < _moveList.Count; pairIdx += 2)
                                {
                                    int moveNum = pairIdx / 2 + 1;
                                    int wIdx = pairIdx;
                                    int bIdx = pairIdx + 1;
                                    int wHalf = pairIdx;       // half-move index (0-based)
                                    int bHalf = pairIdx + 1;

                                    <div class="move-pair">
                                        <span class="move-num">@moveNum.</span>

                                        @* White move *@
                                        @{
                                            var wMove = _moveList[wIdx];
                                            bool wActive = _currentMoveIndex == wHalf;
                                        }
                                        <span class="move-san @(wActive ? "move-san--active" : "")"
                                              @onclick="() => GoToMove(wHalf)">
                                            <span class="move-badge" style="background:@GetQualityColor(wMove.Quality)">@GetQualityIcon(wMove.Quality)</span>
                                            @wMove.San
                                        </span>

                                        @* Black move *@
                                        @if (bIdx < _moveList.Count)
                                        {
                                            var bMove = _moveList[bIdx];
                                            bool bActive = _currentMoveIndex == bHalf;
                                            <span class="move-san @(bActive ? "move-san--active" : "")"
                                                  @onclick="() => GoToMove(bHalf)">
                                                <span class="move-badge" style="background:@GetQualityColor(bMove.Quality)">@GetQualityIcon(bMove.Quality)</span>
                                                @bMove.San
                                            </span>
                                        }
                                    </div>
                                }
                            }
                        </div>

                    </MudTabPanel>

                </MudTabs>
            </MudPaper>

        </section>
    </div>
</MudContainer>

@* Keyboard navigation *@
<div @onkeydown="HandleKeyDown" tabindex="0" id="analysis-keyboard-trap" style="outline:none;position:fixed;opacity:0;pointer-events:none;"></div>

<style>
    html {
        overflow: hidden;
    }

    /* ── Layout ── */
    .analysis-layout {
        --analysis-viewport-height: calc(100dvh - 110px);
        display: grid;
        grid-template-columns: minmax(0, 1fr) clamp(300px, 28vw, 344px);
        gap: 1rem;
        align-items: stretch;
        height: var(--analysis-viewport-height);
        max-height: var(--analysis-viewport-height);
    }

    .analysis-board-column {
        min-height: 0;
        max-height: 100%;
        overflow-y: auto;
    }

    .analysis-board-area {
        width: min(100%, 760px, max(320px, calc(100dvh - 14rem)));
        margin: 0 auto;
        padding: clamp(0.85rem, 1.5vw, 1.25rem) 0;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    /* ── Board shell (ported from play-ai-board-shell) ── */
    .analysis-board-shell {
        position: relative;
        width: 100%;
        padding: 0.75rem;
        border-radius: 22px;
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0)),
            color-mix(in srgb, var(--mud-palette-surface) 88%, black);
        border: 1px solid var(--app-border);
        box-shadow: 0 18px 36px rgba(0, 0, 0, 0.22);
    }

    .analysis-board {
        width: 100%;
        max-width: 760px;
        margin: 0 auto;
    }

    /* ── PGN input row (below board) ── */
    .pgn-input-row {
        width: 100%;
        display: flex;
        align-items: flex-start;
        gap: 0.6rem;
        margin-top: 0.75rem;
    }

    .pgn-input-field {
        flex: 1 1 auto;
        min-width: 0;
    }

    .pgn-analyze-button {
        flex-shrink: 0;
        align-self: stretch;
        min-height: 56px;
    }

    /* ── Players bar (ported from play-ai-players-bar, timer removed) ── */
    .analysis-players-bar {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 0.65rem 0.85rem;
        border-radius: 18px;
        margin-bottom: 0.85rem;
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0)),
            color-mix(in srgb, var(--mud-palette-surface) 88%, black);
        border: 1px solid var(--app-border);
        box-shadow: 0 18px 36px rgba(0, 0, 0, 0.22);
    }

    .analysis-player-block {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        min-width: 0;
        flex: 1 1 0;
    }

    .analysis-player-block-end {
        justify-content: flex-end;
    }

    .analysis-avatar {
        flex-shrink: 0;
        background: rgba(255, 255, 255, 0.04);
    }

    .analysis-avatar-glyph {
        font-size: 1.1rem;
        line-height: 1;
    }

    .analysis-player-copy {
        min-width: 0;
    }

    .analysis-player-copy-end {
        text-align: right;
    }

    .analysis-player-name {
        font-size: 0.95rem;
        font-weight: 700;
        line-height: 1.2;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .analysis-player-subtitle {
        margin-top: 0.15rem;
        font-size: 0.82rem;
        color: var(--app-muted);
    }

    /* ── Side column / panel height ── */
    .analysis-side-column {
        min-height: 0;
        max-height: 100%;
    }

    .analysis-side-paper {
        height: 100%;
        max-height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    /* ── Tabs ── */
    .analysis-tabs .mud-tab {
        font-weight: 600;
        font-size: 0.9rem;
    }

    .analysis-tabs {
        height: 100%;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    .analysis-tabs .mud-tabs-panels {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto;
    }

    /* ── Report: players + accuracy summary ── */
    .report-summary {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 0.75rem;
    }

    .report-player-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
    }

    .report-player__name {
        font-weight: 700;
        font-size: 0.9rem;
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .report-avatar {
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 0.6rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.1rem;
    }

    .report-avatar--white {
        background: var(--app-surface, #fffdf8);
        color: var(--app-text, #1f2937);
        border: 2px solid #f4d35e;
    }

    .report-avatar--black {
        background: color-mix(in srgb, var(--app-surface-2, #f0ebe2) 80%, transparent);
        color: var(--app-text, #1f2937);
    }

    .report-summary__center {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding-top: 1.6rem;
    }

    .accuracy-value {
        font-size: 1.4rem;
        font-weight: 800;
        line-height: 1;
    }

    .accuracy-divider-label {
        color: var(--app-muted);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        white-space: nowrap;
    }

    /* ── Move quality: unified list ── */
    .mq-list {
        display: flex;
        flex-direction: column;
    }

    .mq-list-row {
        display: grid;
        grid-template-columns: 2.5rem 1fr 2.5rem;
        align-items: center;
        gap: 0.5rem;
        padding: 0.45rem 0;
        font-size: 0.88rem;
    }

    .mq-list-row + .mq-list-row {
        border-top: 1px solid color-mix(in srgb, var(--app-border, rgba(71,85,105,0.1)) 60%, transparent);
    }

    .mq-list-val {
        font-weight: 700;
        font-size: 0.92rem;
    }

    .mq-list-val--left { text-align: left; }
    .mq-list-val--right { text-align: right; }

    .mq-list-label {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        font-weight: 500;
    }

    /* ── Analysis tab ── */
    .analysis-eval-bar {
        background: color-mix(in srgb, var(--app-surface-2, #f0ebe2) 60%, transparent);
        border-radius: 0.75rem;
        padding: 0.6rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .analysis-eval-score {
        font-size: 1.5rem;
        font-weight: 800;
    }

    .analysis-nav {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
    }

    /* ── Move list ── */
    .move-list {
        max-height: 420px;
        overflow-y: auto;
        border: 1px solid var(--app-border, rgba(71,85,105,0.14));
        border-radius: 0.75rem;
        padding: 0.5rem;
    }

    .move-pair {
        display: grid;
        grid-template-columns: 1.8rem 1fr 1fr;
        gap: 0.15rem 0.25rem;
        align-items: center;
        padding: 0.18rem 0.25rem;
        border-radius: 0.4rem;
    }

    .move-pair:hover { background: color-mix(in srgb, var(--app-surface-2, #f0ebe2) 60%, transparent); }

    .move-num {
        font-size: 0.78rem;
        color: var(--app-muted);
        font-weight: 600;
        text-align: right;
        padding-right: 0.3rem;
    }

    .move-san {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.88rem;
        font-weight: 500;
        cursor: pointer;
        padding: 0.2rem 0.4rem;
        border-radius: 0.35rem;
        transition: background 0.15s;
    }

    .move-san:hover { background: color-mix(in srgb, var(--app-accent, #2f6f5e) 15%, transparent); }

    .move-san--active {
        background: color-mix(in srgb, var(--app-accent, #2f6f5e) 22%, transparent);
        font-weight: 700;
        color: var(--app-accent, #2f6f5e);
    }

    .move-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.1rem;
        height: 1.1rem;
        border-radius: 999px;
        font-size: 0.62rem;
        flex-shrink: 0;
        color: #fff;
    }

    /* ── Misc ── */
    .muted-text { color: var(--app-muted); }

    .mb-1 { margin-bottom: 0.25rem !important; }
    .mb-2 { margin-bottom: 0.5rem !important; }
    .mb-3 { margin-bottom: 0.75rem !important; }
    .mb-4 { margin-bottom: 1rem !important; }
    .mt-4 { margin-top: 1rem !important; }

    @@media (max-width: 1360px) {
        .analysis-board-area {
            max-width: 720px;
        }
    }

    @@media (max-width: 1100px) {
        html {
            overflow: auto;
        }

        .analysis-layout {
            grid-template-columns: 1fr;
            height: auto;
            max-height: none;
        }

        .analysis-board-column,
        .analysis-side-column {
            max-height: none;
            overflow: visible;
        }

        .analysis-side-paper {
            height: auto;
            max-height: none;
        }

        .analysis-tabs .mud-tabs-panels {
            overflow-y: visible;
        }
    }

    @@media (max-width: 520px) {
        .report-summary {
            grid-template-columns: 1fr auto 1fr;
            gap: 0.4rem;
        }

        .analysis-board-shell {
            padding: 0.55rem;
            border-radius: 20px;
        }

        .analysis-players-bar {
            flex-wrap: wrap;
        }

        .pgn-input-row {
            flex-direction: column;
        }

        .pgn-analyze-button {
            width: 100%;
        }
    }
</style>

@code {
    [Parameter] public int? Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private string PgnInput { get; set; } = "";
    private string CurrentEvaluation { get; set; } = "0.0";
    private bool IsAnalyzing { get; set; } = false;
    private string AnalyzeButtonText => IsAnalyzing ? "Анализируем..." : "Начать анализ";

    private bool _boardReady;
    private bool _analysisComplete;
    private const string StockfishEngineKey = "stockfish18Lite";
    private const string StockfishEngineLabel = "Stockfish 18 Lite";

    private string _engineStatusText = "Загрузите PGN и нажмите «Начать анализ».";
    private DotNetObjectReference<Analysis>? objRef;
    private List<double> ChartData = new();
    private string[] _emptyLabels = Array.Empty<string>();
    private List<ChartSeries> ChartSeries = new();
    private string? _userId;
    private UserGame? _loadedGame;

    private double? _whiteAccuracy;
    private double? _blackAccuracy;

    private string _whitePlayer = "Белые";
    private string _blackPlayer = "Чёрные";

    private int _currentMoveIndex = -1;
    private int _totalMoves = 0;

    // Move list entry
    private record MoveEntry(string San, string Quality);
    private List<MoveEntry> _moveList = new();

    // Per-side move quality counts
    private Dictionary<string, int> MoveQualitiesWhite = new()
    {
        { "Brilliant", 0 }, { "Excellent", 0 }, { "Good", 0 }, { "Best", 0 },
        { "Inaccuracy", 0 }, { "Mistake", 0 }, { "Blunder", 0 }
    };

    private Dictionary<string, int> MoveQualitiesBlack = new()
    {
        { "Brilliant", 0 }, { "Excellent", 0 }, { "Good", 0 }, { "Best", 0 },
        { "Inaccuracy", 0 }, { "Mistake", 0 }, { "Blunder", 0 }
    };

    // Good moves group
    private record MoveQualityRowDef(string Key, string Label, string Color, string Icon);

    private readonly List<MoveQualityRowDef> MoveQualityGoodRows = new()
    {
        new("Brilliant",  "Бриллиантовые", "#00bcd4", "!!"),
        new("Excellent",  "Отличные",       "#4caf50", "!"),
        new("Best",       "Лучшие",         "#2196f3", "★"),
        new("Good",       "Хорошие",        "#8bc34a", "✓"),
    };

    private readonly List<MoveQualityRowDef> MoveQualityBadRows = new()
    {
        new("Inaccuracy", "Неточности", "#ff9800", "?"),
        new("Mistake",    "Ошибки",     "#f44336", "?!"),
        new("Blunder",    "Зевки",      "#b71c1c", "??"),
    };

    private List<MoveQualityRowDef> MoveQualityAllRows =>
        MoveQualityGoodRows.Concat(MoveQualityBadRows).ToList();

    private string GetQualityColor(string q) => q switch
    {
        "Brilliant"  => "#00bcd4",
        "Excellent"  => "#4caf50",
        "Good"       => "#8bc34a",
        "Best"       => "#2196f3",
        "Inaccuracy" => "#ff9800",
        "Mistake"    => "#f44336",
        "Blunder"    => "#b71c1c",
        _ => "#888"
    };

    private string GetQualityIcon(string q) => q switch
    {
        "Brilliant"  => "!!",
        "Excellent"  => "!",
        "Good"       => "✓",
        "Best"       => "★",
        "Inaccuracy" => "?",
        "Mistake"    => "?!",
        "Blunder"    => "??",
        _ => "·"
    };

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask is null) return;
        var authState = await AuthenticationStateTask;
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var user = await UserManager.GetUserAsync(authState.User);
            _userId = user?.Id;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            _boardReady = await JS.InvokeAsync<bool>("analysisBridge.init", objRef, StockfishEngineKey);

            if (!_boardReady)
            {
                _engineStatusText = "Не удалось подготовить доску анализа.";
                Snackbar.Add(_engineStatusText, Severity.Error);
                StateHasChanged();
                return;
            }

            if (Id.HasValue)
                await LoadSavedGameAsync(Id.Value);
            else
                _engineStatusText = "Доска готова. Загрузите PGN и нажмите «Начать анализ».";

            UpdateChart();
            StateHasChanged();

            // Register keyboard handler
            await JS.InvokeVoidAsync("analysisKeyboard.init", objRef);
        }
    }

    private async Task LoadSavedGameAsync(int id)
    {
        if (string.IsNullOrWhiteSpace(_userId))
        {
            _engineStatusText = "Войдите в аккаунт, чтобы открыть сохранённую партию.";
            Snackbar.Add(_engineStatusText, Severity.Warning);
            return;
        }

        var game = await UserGameService.GetUserGameAsync(_userId, id);
        if (game is null || string.IsNullOrWhiteSpace(game.PgnContent))
        {
            _engineStatusText = "Партия не найдена.";
            Snackbar.Add(_engineStatusText, Severity.Warning);
            return;
        }

        _loadedGame = game;
        PgnInput = game.PgnContent;
        _whiteAccuracy = game.WhiteAccuracy;
        _blackAccuracy = game.BlackAccuracy;
        _analysisComplete = game.IsAnalyzed;
        _whitePlayer = game.WhitePlayer;
        _blackPlayer = game.BlackPlayer;

        ResetQualities();
        ChartData.Clear();
        CurrentEvaluation = "0.0";

        var loaded = await JS.InvokeAsync<bool>("analysisBridge.loadPgn", PgnInput);
        if (loaded)
        {
            var moves = await JS.InvokeAsync<string[]>("analysisExtra.getMoveList");
            _moveList = moves?.Select(m => new MoveEntry(m, "Best")).ToList() ?? new();
            _totalMoves = _moveList.Count;
        }
        else
        {
            Snackbar.Add("Не удалось разобрать PGN этой партии.", Severity.Error);
        }
        _engineStatusText = loaded
            ? $"Партия {game.WhitePlayer} — {game.BlackPlayer} загружена. Нажмите «Начать анализ»."
            : "Не удалось разобрать PGN этой партии.";
    }

    private async Task LoadPgnAndAnalyze()
    {
        if (string.IsNullOrWhiteSpace(PgnInput))
        {
            Snackbar.Add("Вставьте PGN партии перед запуском анализа.", Severity.Warning);
            return;
        }

        if (!_boardReady) return;

        ResetQualities();
        ChartData.Clear();
        UpdateChart();
        CurrentEvaluation = "0.0";
        _analysisComplete = false;
        _whiteAccuracy = null;
        _blackAccuracy = null;
        _currentMoveIndex = -1;
        _moveList.Clear();

        // Parse player names from PGN headers
        ParsePgnHeaders(PgnInput);

        var loaded = await JS.InvokeAsync<bool>("analysisBridge.loadPgn", PgnInput);
        if (!loaded)
        {
            Snackbar.Add("Не удалось разобрать PGN. Проверьте формат партии.", Severity.Error);
            StateHasChanged();
            return;
        }

        // Ask JS for the move list
        var moves = await JS.InvokeAsync<string[]>("analysisExtra.getMoveList");
        _moveList = moves?.Select(m => new MoveEntry(m, "Best")).ToList() ?? new();
        _totalMoves = _moveList.Count;
        StateHasChanged();

        await StartAnalysis();
    }

    private void ParsePgnHeaders(string pgn)
    {
        foreach (var line in pgn.Split('\n'))
        {
            var trimmed = line.Trim();
            if (trimmed.StartsWith("[White "))
                _whitePlayer = trimmed.Replace("[White \"", "").TrimEnd(']').TrimEnd('"').Trim();
            else if (trimmed.StartsWith("[Black "))
                _blackPlayer = trimmed.Replace("[Black \"", "").TrimEnd(']').TrimEnd('"').Trim();
        }
        if (string.IsNullOrWhiteSpace(_whitePlayer)) _whitePlayer = "Белые";
        if (string.IsNullOrWhiteSpace(_blackPlayer)) _blackPlayer = "Чёрные";
    }

    private void ResetQualities()
    {
        foreach (var key in MoveQualitiesWhite.Keys.ToList())
        {
            MoveQualitiesWhite[key] = 0;
            MoveQualitiesBlack[key] = 0;
        }
    }

