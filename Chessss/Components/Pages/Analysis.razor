@page "/analysis"
@page "/analysis/{Id:int}"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.JSInterop
@using Chessss.Models
@using Chessss.Services
@inject IJSRuntime JS
@inject UserManager<ApplicationUser> UserManager
@inject UserGameService UserGameService
@using System.Text.Json
@implements IAsyncDisposable

<PageTitle>Анализ партии</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-4 page-shell">
    <div class="analysis-layout chess-layout">
        <section class="analysis-board-column">
            <MudPaper Elevation="0" Class="analysis-board-panel chess-board-panel">
                <div id="analysis-board" class="analysis-board"></div>

                <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-4 analysis-board-actions" Spacing="2">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Filled" Color="Color.Primary" OnClick="PrevMove" />
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" Variant="Variant.Filled" Color="Color.Primary" OnClick="NextMove" />
                </MudStack>

                <MudText Typo="Typo.h5" Class="mt-4 text-center">Оценка: @CurrentEvaluation</MudText>
            </MudPaper>
        </section>

        <section class="analysis-side-column">
            <MudPaper Class="pa-4 mb-4 chess-side-panel" Elevation="0">
                <MudText Typo="Typo.h6" Class="mb-4">Анализ</MudText>
                <MudText Typo="Typo.subtitle2">Движок</MudText>
                <MudText Typo="Typo.body2" Class="mb-3">Stockfish 18 Lite</MudText>
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                    @_engineStatusText
                </MudAlert>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="StartAnalysis" FullWidth="true" Disabled="@(IsAnalyzing || !_boardReady)">@AnalyzeButtonText</MudButton>
            </MudPaper>

            <MudPaper Class="pa-4 chess-side-panel" Elevation="0">
                <MudTextField @bind-Value="PgnInput" Label="Вставьте PGN партии" Lines="5" Variant="Variant.Outlined" />
                <MudStack Row="true" Class="mt-3" Spacing="2" Justify="Justify.FlexStart" Wrap="Wrap.Wrap">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="LoadPgn">Загрузить PGN</MudButton>
                </MudStack>
            </MudPaper>
            
            <MudPaper Class="pa-4 mt-4 chess-side-panel" Elevation="0">
                <MudText Typo="Typo.h6" Class="mb-2">Качество ходов</MudText>
                <MudGrid>
                    <MudItem xs="6">
                        <MudText Color="Color.Info"><b>Бриллиантовые:</b> @MoveQualities["Brilliant"]</MudText>
                        <MudText Color="Color.Success"><b>Отличные:</b> @MoveQualities["Excellent"]</MudText>
                        <MudText Color="Color.Success"><b>Хорошие:</b> @MoveQualities["Good"]</MudText>
                        <MudText Color="Color.Primary"><b>Лучшие:</b> @MoveQualities["Best"]</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Color="Color.Warning"><b>Неточности:</b> @MoveQualities["Inaccuracy"]</MudText>
                        <MudText Color="Color.Error"><b>Ошибки:</b> @MoveQualities["Mistake"]</MudText>
                        <MudText Color="Color.Error"><b>Зевки:</b> @MoveQualities["Blunder"]</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
            
            <MudPaper Class="pa-4 mt-4 chess-side-panel analysis-chart-panel" Elevation="0">
                <MudText Typo="Typo.h6">График оценки (CAPS)</MudText>
                @if (ChartData != null && ChartData.Count > 0)
                {
                    <MudChart ChartType="ChartType.Line" ChartSeries="@ChartSeries" XAxisLabels="@ChartLabels" Width="100%" Height="250px" />
                }
                else
                {
                    <MudText Class="mt-4">Загрузите партию или сделайте ходы для отображения графика.</MudText>
                }
            </MudPaper>
        </section>
    </div>
</MudContainer>

<style>
    .analysis-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(20rem, 24rem);
        gap: 1rem;
        align-items: start;
    }

    .analysis-board-panel {
        padding: clamp(0.85rem, 1.5vw, 1.25rem);
    }

    .analysis-board {
        width: min(100%, 760px);
        margin: 0 auto;
    }

    .analysis-board-actions {
        width: min(100%, 760px);
        margin-inline: auto;
    }

    .analysis-chart-panel {
        min-height: 20rem;
    }

    @@media (max-width: 1080px) {
        .analysis-layout {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    [Parameter] public int? Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private string PgnInput { get; set; } = "";
    private string CurrentEvaluation { get; set; } = "0.0";
    private bool IsAnalyzing { get; set; } = false;
    private string AnalyzeButtonText => IsAnalyzing ? "Анализируем..." : "Начать анализ";
    
    private bool _boardReady;
    private const string StockfishEngineKey = "stockfish18Lite";
    private const string StockfishEngineLabel = "Stockfish 18 Lite";

    private string _engineStatusText = "Загрузите PGN и нажмите «Начать анализ».";
    private string _selectedEngineKey = StockfishEngineKey;
    private DotNetObjectReference<Analysis>? objRef;
    private List<double> ChartData = new();
    private string[] ChartLabels = Array.Empty<string>();
    private List<ChartSeries> ChartSeries = new();
    private string? _userId;
    private UserGame? _loadedGame;
    
    private Dictionary<string, int> MoveQualities = new()
    {
        { "Brilliant", 0 },
        { "Excellent", 0 },
        { "Good", 0 },
        { "Best", 0 },
        { "Inaccuracy", 0 },
        { "Mistake", 0 },
        { "Blunder", 0 }
    };

    private string GetSelectedEngineDescription()
    {
        return StockfishEngineLabel;
    }

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask is null)
        {
            return;
        }

        var authState = await AuthenticationStateTask;
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var user = await UserManager.GetUserAsync(authState.User);
            _userId = user?.Id;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            _selectedEngineKey = StockfishEngineKey;
            _boardReady = await JS.InvokeAsync<bool>("analysisBridge.init", objRef, StockfishEngineKey);

            if (!_boardReady)
            {
                _engineStatusText = "Не удалось подготовить доску анализа.";
                StateHasChanged();
                return;
            }

            if (Id.HasValue)
            {
                await LoadSavedGameAsync(Id.Value);
            }
            else
            {
                _engineStatusText = "Доска готова. Загрузите PGN и нажмите «Начать анализ».";
            }

            UpdateChart();
            StateHasChanged();
        }
    }

    private async Task LoadSavedGameAsync(int id)
    {
        if (string.IsNullOrWhiteSpace(_userId))
        {
            _engineStatusText = "Войдите в аккаунт, чтобы открыть сохранённую партию.";
            return;
        }

        var game = await UserGameService.GetUserGameAsync(_userId, id);

        if (game is null || string.IsNullOrWhiteSpace(game.PgnContent))
        {
            _engineStatusText = "Партия не найдена.";
            return;
        }

        _loadedGame = game;
        PgnInput = game.PgnContent;

        ResetQualities();
        ChartData.Clear();
        CurrentEvaluation = "0.0";

        var loaded = await JS.InvokeAsync<bool>("analysisBridge.loadPgn", PgnInput);
        _engineStatusText = loaded
            ? $"Партия {game.WhitePlayer} — {game.BlackPlayer} загружена. Нажмите «Начать анализ»."
            : "Не удалось разобрать PGN этой партии.";
    }

    private async Task LoadPgn()
    {
        if (!string.IsNullOrWhiteSpace(PgnInput))
        {
            ResetQualities();
            ChartData.Clear();
            UpdateChart();
            CurrentEvaluation = "0.0";
            
            await JS.InvokeAsync<bool>("analysisBridge.loadPgn", PgnInput);
        }
    }

    private void ResetQualities()
    {
        foreach (var key in MoveQualities.Keys.ToList())
        {
            MoveQualities[key] = 0;
        }
    }

    private void LoadLastGame() { }
    private void LoadFromChessCom() { }

    private async Task PrevMove()
    {
        await JS.InvokeVoidAsync("analysisBridge.prevMove");
    }

    private async Task NextMove()
    {
        await JS.InvokeVoidAsync("analysisBridge.nextMove");
    }

    private async Task StartAnalysis()
    {
        if (!_boardReady)
        {
            return;
        }

        IsAnalyzing = true;
        ResetQualities();
        _engineStatusText = $"Загружаем {GetSelectedEngineDescription()}...";
        StateHasChanged();
        var started = await JS.InvokeAsync<bool>("analysisBridge.analyzeAllMoves", StockfishEngineKey);

        if (!started)
        {
            IsAnalyzing = false;
            _engineStatusText = "Stockfish 18 Lite не загрузился. Проверьте файлы движка и консоль браузера.";
        }
    }

    [JSInvokable]
    public async Task OnAnalysisComplete()
    {
        IsAnalyzing = false;
        CalculateMoveQualities();
        StateHasChanged();

        if (_loadedGame is not null && !string.IsNullOrWhiteSpace(_userId))
        {
            var (whiteAccuracy, blackAccuracy) = CalculateAccuracy();
            await UserGameService.SaveAnalysisResultAsync(_loadedGame.Id, _userId, whiteAccuracy, blackAccuracy);
            _loadedGame.IsAnalyzed = true;
            _loadedGame.WhiteAccuracy = whiteAccuracy;
            _loadedGame.BlackAccuracy = blackAccuracy;
        }
    }

    private (double WhiteAccuracy, double BlackAccuracy) CalculateAccuracy()
    {
        // Simple accuracy estimate: each half-move's centipawn loss (relative to
        // the previous evaluation) reduces a 100% baseline. This mirrors the
        // move-quality buckets used in CalculateMoveQualities, just expressed
        // as a single percentage per side.
        double whiteLossSum = 0;
        double blackLossSum = 0;
        int whiteMoves = 0;
        int blackMoves = 0;

        for (int i = 1; i < ChartData.Count; i++)
        {
            double prevEval = ChartData[i - 1];
            double currEval = ChartData[i];
            double diff = (i % 2 != 0) ? (currEval - prevEval) : (prevEval - currEval);
            double loss = diff < 0 ? -diff : 0;

            if (i % 2 != 0)
            {
                whiteLossSum += loss;
                whiteMoves++;
            }
            else
            {
                blackLossSum += loss;
                blackMoves++;
            }
        }

        double whiteAccuracy = whiteMoves == 0 ? 100.0 : Math.Clamp(100.0 - (whiteLossSum / whiteMoves) * 25.0, 0, 100);
        double blackAccuracy = blackMoves == 0 ? 100.0 : Math.Clamp(100.0 - (blackLossSum / blackMoves) * 25.0, 0, 100);

        return (Math.Round(whiteAccuracy, 2), Math.Round(blackAccuracy, 2));
    }

    private void CalculateMoveQualities()
    {
        ResetQualities();
        // ChartData contains evaluation after each move.
        // Index 0 is starting position, Index 1 is after move 1 (White), Index 2 is after move 2 (Black), etc.
        for (int i = 1; i < ChartData.Count; i++)
        {
            double prevEval = ChartData[i - 1];
            double currEval = ChartData[i];
            
            // Calculate difference from the perspective of the player who just moved
            // If White moved (i is odd), White wants currEval to be higher. diff = currEval - prevEval. Wait.
            // Actually, if White moves, a drop in evaluation is bad for White.
            // If Black moves (i is even), a rise in evaluation is bad for Black.
            // Since ChartData is always from White's perspective (+ means White is winning):
            double diff = (i % 2 != 0) ? (currEval - prevEval) : (prevEval - currEval);
            
            if (diff >= 0.0)
            {
                MoveQualities["Best"]++;
            }
            else if (diff > -0.2)
            {
                MoveQualities["Excellent"]++;
            }
            else if (diff > -0.5)
            {
                MoveQualities["Good"]++;
            }
            else if (diff > -1.0)
            {
                MoveQualities["Inaccuracy"]++;
            }
            else if (diff > -2.0)
            {
                MoveQualities["Mistake"]++;
            }
            else
            {
                MoveQualities["Blunder"]++;
            }
        }
    }

    [JSInvokable]
    public void OnMoveChanged(int moveIndex)
    {
        StateHasChanged();
    }

    [JSInvokable]
    public void OnEvaluationReceived(int moveIndex, JsonElement evalObj)
    {
        if (evalObj.TryGetProperty("type", out var typeProp) && evalObj.TryGetProperty("value", out var valProp))
        {
            string type = typeProp.GetString() ?? "cp";
            int val = valProp.GetInt32();
            bool isWhiteToMove = true;
            if (evalObj.TryGetProperty("isWhiteToMove", out var whiteMoveProp))
            {
                isWhiteToMove = whiteMoveProp.GetBoolean();
            }
            
            // Stockfish returns score from the side to move's perspective.
            // We want positive values for White winning, negative for Black.
            if (!isWhiteToMove)
            {
                val = -val;
            }
            
            double score = type == "cp" ? Math.Round(val / 100.0, 2) : (val > 0 ? 10.0 : -10.0);
            
            // Update chart data for the current move index
            int idx = moveIndex + 1; // moveIndex -1 is starting pos, index 0
            while (ChartData.Count <= idx) 
            {
                ChartData.Add(0);
            }
            ChartData[idx] = score;
            
            UpdateChart();
            
            // Only update current evaluation text if this is the current move on the board
            // Wait, we need to check if we are analyzing all.
            // But we don't know that here directly. We can just update it, it will flicker quickly during analysis.
            if (type == "mate")
            {
                CurrentEvaluation = $"M{Math.Abs(val)} ({(val > 0 ? "Белые" : "Черные")} выигрывают)";
            }
            else
            {
                CurrentEvaluation = (score > 0 ? "+" : "") + score.ToString("0.00");
            }
            
            StateHasChanged();
        }
    }

    private void UpdateChart()
    {
        ChartLabels = Enumerable.Range(0, Math.Max(1, ChartData.Count)).Select(i => i.ToString()).ToArray();
        ChartSeries = new List<ChartSeries>
        {
            new ChartSeries { Name = "Оценка", Data = ChartData.ToArray() }
        };
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("analysisBridge.destroy");
        }
        catch (JSDisconnectedException)
        {
        }

        objRef?.Dispose();
    }
}


