    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "ArrowLeft") await PrevMove();
        else if (e.Key == "ArrowRight") await NextMove();
        else if (e.Key == "ArrowUp" || e.Key == "Home") await GoFirst();
        else if (e.Key == "ArrowDown" || e.Key == "End") await GoLast();
    }

    private async Task StartAnalysis()
    {
        if (!_boardReady) return;

        IsAnalyzing = true;
        _analysisComplete = false;
        ResetQualities();
        _engineStatusText = $"Загружаем {StockfishEngineLabel}...";
        StateHasChanged();

        var started = await JS.InvokeAsync<bool>("analysisBridge.analyzeAllMoves", StockfishEngineKey);

        if (!started)
        {
            IsAnalyzing = false;
            _engineStatusText = "Stockfish 18 Lite не загрузился. Проверьте файлы движка и консоль браузера.";
            Snackbar.Add(_engineStatusText, Severity.Error);
        }
    }

    [JSInvokable]
    public async Task OnAnalysisComplete()
    {
        IsAnalyzing = false;
        _analysisComplete = true;
        CalculateMoveQualities();
        UpdateMoveListQualities();
        var (wa, ba) = CalculateAccuracy();
        _whiteAccuracy = wa;
        _blackAccuracy = ba;
        StateHasChanged();

        if (_loadedGame is not null && !string.IsNullOrWhiteSpace(_userId))
        {
            await UserGameService.SaveAnalysisResultAsync(_loadedGame.Id, _userId, wa, ba);
            _loadedGame.IsAnalyzed = true;
            _loadedGame.WhiteAccuracy = wa;
            _loadedGame.BlackAccuracy = ba;
        }
    }

    private void UpdateMoveListQualities()
    {
        // Assign quality labels to each move based on ChartData diffs
        var updated = new List<MoveEntry>();
        for (int i = 0; i < _moveList.Count; i++)
        {
            int chartIdx = i + 1;
            string quality = "Best";
            if (chartIdx < ChartData.Count && chartIdx > 0)
            {
                double prevEval = ChartData[chartIdx - 1];
                double currEval = ChartData[chartIdx];
                double diff = (i % 2 == 0) ? (currEval - prevEval) : (prevEval - currEval);
                quality = diff >= 0.0 ? "Best"
                    : diff > -0.2 ? "Excellent"
                    : diff > -0.5 ? "Good"
                    : diff > -1.0 ? "Inaccuracy"
                    : diff > -2.0 ? "Mistake"
                    : "Blunder";
            }
            updated.Add(new MoveEntry(_moveList[i].San, quality));
        }
        _moveList = updated;
    }

    private (double WhiteAccuracy, double BlackAccuracy) CalculateAccuracy()
    {
        double whiteLossSum = 0, blackLossSum = 0;
        int whiteMoves = 0, blackMoves = 0;

        for (int i = 1; i < ChartData.Count; i++)
        {
            double prevEval = ChartData[i - 1];
            double currEval = ChartData[i];
            double diff = (i % 2 != 0) ? (currEval - prevEval) : (prevEval - currEval);
            double loss = diff < 0 ? -diff : 0;

            if (i % 2 != 0) { whiteLossSum += loss; whiteMoves++; }
            else             { blackLossSum += loss; blackMoves++; }
        }

        double wa = whiteMoves == 0 ? 100.0 : Math.Clamp(100.0 - (whiteLossSum / whiteMoves) * 25.0, 0, 100);
        double ba = blackMoves == 0 ? 100.0 : Math.Clamp(100.0 - (blackLossSum / blackMoves) * 25.0, 0, 100);
        return (Math.Round(wa, 1), Math.Round(ba, 1));
    }

    private void CalculateMoveQualities()
    {
        ResetQualities();
        for (int i = 1; i < ChartData.Count; i++)
        {
            double prevEval = ChartData[i - 1];
            double currEval = ChartData[i];
            double diff = (i % 2 != 0) ? (currEval - prevEval) : (prevEval - currEval);

            string bucket = diff >= 0.0 ? "Best"
                : diff > -0.2 ? "Excellent"
                : diff > -0.5 ? "Good"
                : diff > -1.0 ? "Inaccuracy"
                : diff > -2.0 ? "Mistake"
                : "Blunder";

            bool isWhiteMove = (i % 2 != 0);
            if (isWhiteMove) MoveQualitiesWhite[bucket]++;
            else             MoveQualitiesBlack[bucket]++;
        }
    }

    [JSInvokable]
    public void OnMoveChanged(int moveIndex)
    {
        _currentMoveIndex = moveIndex;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnEvaluationReceived(int moveIndex, JsonElement evalObj)
    {
        if (!evalObj.TryGetProperty("type", out var typeProp) || !evalObj.TryGetProperty("value", out var valProp))
            return;

        string type = typeProp.GetString() ?? "cp";
        int val = valProp.GetInt32();
        bool isWhiteToMove = true;
        if (evalObj.TryGetProperty("isWhiteToMove", out var wp))
            isWhiteToMove = wp.GetBoolean();

        if (!isWhiteToMove) val = -val;

        double score = type == "cp" ? Math.Round(val / 100.0, 2) : (val > 0 ? 10.0 : -10.0);

        int idx = moveIndex + 1;
        while (ChartData.Count <= idx) ChartData.Add(0);
        ChartData[idx] = score;

        UpdateChart();

        if (type == "mate")
            CurrentEvaluation = $"М{Math.Abs(val)} ({(val > 0 ? "Белые" : "Чёрные")} выигрывают)";
        else
            CurrentEvaluation = (score > 0 ? "+" : "") + score.ToString("0.00");

        StateHasChanged();
    }

    private void UpdateChart()
    {
        // Empty labels — no move numbers on X axis
        _emptyLabels = new string[Math.Max(1, ChartData.Count)];
        ChartSeries = new List<ChartSeries>
        {
            new ChartSeries { Name = "Оценка", Data = ChartData.ToArray() }
        };
    }

