@page "/"

<PageTitle>UltraChess</PageTitle>

<div class="page-shell home-page">
    <section class="home-hero app-card">
        <div class="home-hero__copy">
            <MudText Typo="Typo.h2" Class="home-hero__title">Играй, анализируй и прокачивай шахматы в одном интерфейсе.</MudText>

            <div class="home-hero__actions">
                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large" Href="/playwithai">
                    Играть с ИИ
                </MudButton>
            </div>
        </div>

    </section>

    <section class="responsive-grid home-features">
        <MudPaper Elevation="0" Class="app-card home-feature">
            <MudIcon Icon="@Icons.Material.Filled.AutoGraph" Color="Color.Success" Size="Size.Large" Class="mb-3" />
            <MudText Typo="Typo.h6">Играй и анализируй партии</MudText>
            <MudText Typo="Typo.body2" Class="home-feature__text">
                Играйте и разберайте партии с помощью мощного движка Stockfish 18 Lite, который можно настроить под ваш уровень игры.
            </MudText>
        </MudPaper>

        <MudPaper Elevation="0" Class="app-card home-feature">
            <MudIcon Icon="@Icons.Material.Filled.Psychology" Color="Color.Info" Size="Size.Large" Class="mb-3" />
            <MudText Typo="Typo.h6">20 уровней сложности</MudText>
            <MudText Typo="Typo.body2" Class="home-feature__text">
                Гибкая настройка сложности от новичка до эксперта позволяет каждому найти подходящего соперника и улучшать свои навыки.
            </MudText>
        </MudPaper>

        <MudPaper Elevation="0" Class="app-card home-feature">
            <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Warning" Size="Size.Large" Class="mb-3" />
            <MudText Typo="Typo.h6">Личный профиль</MudText>
            <MudText Typo="Typo.body2" Class="home-feature__text">
                Храните статистику, рейтинг, аватар и историю партий в одном месте без хаотичных экранов.
            </MudText>
        </MudPaper>
    </section>
</div>

<style>
    .home-page {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding-block: 0.5rem 1.5rem;
    }

    .home-hero {
        display: grid;
        grid-template-columns: minmax(0, 1.4fr) minmax(18rem, 0.85fr);
        gap: 1.25rem;
        padding: clamp(1.2rem, 3vw, 2rem);
        position: relative;
        overflow: hidden;
        background:
            radial-gradient(circle at top right, color-mix(in srgb, var(--app-accent-2) 18%, transparent), transparent 30%),
            linear-gradient(135deg, color-mix(in srgb, var(--app-surface) 94%, transparent), color-mix(in srgb, var(--app-surface-2) 90%, transparent));
    }

    .home-hero__eyebrow {
        color: var(--app-accent-2);
        letter-spacing: 0.16em;
        font-weight: 700;
    }

    .home-hero__title {
        font-weight: 800;
        line-height: 1.02;
    }

    .home-hero__subtitle {
        max-width: 60ch;
        color: var(--app-muted);
        margin-top: 1rem;
    }

    .home-hero__actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
    }

    .home-hero__panel {
        display: grid;
        gap: 0.85rem;
        align-content: center;
    }

    .home-hero__badge,
    .home-hero__metric {
        padding: 1rem 1.1rem;
        border-radius: 1rem;
        border: 1px solid var(--app-border);
        background: color-mix(in srgb, var(--app-surface-2) 72%, transparent);
    }

    .home-hero__badge {
        font-weight: 700;
        color: var(--app-accent);
    }

    .home-hero__metric {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }

    .home-hero__metric span,
    .home-feature__text {
        color: var(--app-muted);
    }

    .home-hero__metric strong {
        font-size: 1.05rem;
    }

    .home-feature {
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
    }

    @@media (max-width: 920px) {
        .home-hero {
            grid-template-columns: 1fr;
        }

        .home-hero__title {
            max-width: none;
        }
    }
</style>
