@page "/"

<PageTitle>UltraChess</PageTitle>

<div class="page-shell home-page">
    <section class="home-hero app-card">
        <div class="home-hero__pattern" aria-hidden="true"></div>

        <div class="home-hero__copy">
            <MudText Typo="Typo.h2" Class="home-hero__title">Играй, анализируй и прокачивай свои навыки с помощью UltraChess.</MudText>

            <MudText Typo="Typo.body1" Class="home-hero__subtitle">
                Выбери уровень соперника, сыграй партию и сразу получи разбор ходов от ИИ.
            </MudText>

            <div class="home-hero__actions">
                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large" StartIcon="@Icons.Material.Filled.SportsEsports" Href="/playwithai">
                    Играть с ИИ
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Large" StartIcon="@Icons.Material.Filled.Insights" Href="/analysis">
                    ИИ анализ партий
                </MudButton>
            </div>
        </div>
    </section>

    <section class="responsive-grid home-features">
        <MudPaper Elevation="0" Class="app-card home-feature">
            <MudIcon Icon="@Icons.Material.Filled.AutoGraph" Color="Color.Success" Size="Size.Large" Class="mb-2" />
            <MudText Typo="Typo.h6">Играй и анализируй партии</MudText>
            <MudText Typo="Typo.body2" Class="home-feature__text">
                Играйте и разберайте партии с помощью мощного движка Stockfish 18 Lite, который можно настроить под ваш уровень игры.
            </MudText>
        </MudPaper>

        <MudPaper Elevation="0" Class="app-card home-feature">
            <MudIcon Icon="@Icons.Material.Filled.Psychology" Color="Color.Info" Size="Size.Large" Class="mb-2" />
            <MudText Typo="Typo.h6">20 уровней сложности</MudText>
            <MudText Typo="Typo.body2" Class="home-feature__text">
                Гибкая настройка сложности от новичка до эксперта позволяет каждому найти подходящего соперника и улучшать свои навыки.
            </MudText>
        </MudPaper>

        <MudPaper Elevation="0" Class="app-card home-feature">
            <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Warning" Size="Size.Large" Class="mb-2" />
            <MudText Typo="Typo.h6">Личный профиль</MudText>
            <MudText Typo="Typo.body2" Class="home-feature__text">
                Храните статистику, рейтинг, аватар и историю партий в одном месте без хаотичных экранов.
            </MudText>
        </MudPaper>
    </section>
</div>

<style>
    .home-page {
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
        padding-block: 0.5rem 1rem;
        height: 100%;
        min-height: 0;
    }

    .home-hero {
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        padding: clamp(1.4rem, 3vw, 2rem) clamp(1.4rem, 4vw, 2.5rem);
        background:
            radial-gradient(circle at top right, color-mix(in srgb, var(--app-accent-2) 16%, transparent), transparent 55%),
            linear-gradient(135deg, color-mix(in srgb, var(--app-surface) 95%, transparent), color-mix(in srgb, var(--app-surface-2) 92%, transparent));
    }

    .home-hero__pattern {
        position: absolute;
        inset: 0;
        width: 46%;
        margin-left: auto;
        background-image:
            linear-gradient(45deg, color-mix(in srgb, var(--app-accent) 10%, transparent) 25%, transparent 25%, transparent 75%, color-mix(in srgb, var(--app-accent) 10%, transparent) 75%),
            linear-gradient(45deg, color-mix(in srgb, var(--app-accent) 10%, transparent) 25%, transparent 25%, transparent 75%, color-mix(in srgb, var(--app-accent) 10%, transparent) 75%);
        background-size: 44px 44px;
        background-position: 0 0, 22px 22px;
        -webkit-mask-image: linear-gradient(to left, #000 20%, transparent 85%);
        mask-image: linear-gradient(to left, #000 20%, transparent 85%);
        pointer-events: none;
    }

    .home-hero__copy {
        position: relative;
        z-index: 1;
        max-width: 46rem;
    }

    .home-hero__title {
        font-size: clamp(1.6rem, 2.7vw, 2.4rem);
        font-weight: 800;
        line-height: 1.18;
        margin: 0;
    }

    .home-hero__subtitle {
        margin-top: 0.65rem;
        max-width: 42ch;
        color: var(--app-muted);
    }

    .home-hero__actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1.25rem;
    }

    .home-features {
        gap: 1rem;
    }

    .home-feature {
        padding: 1.1rem 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .home-feature:hover {
        transform: translateY(-2px);
    }

    .home-feature__text {
        color: var(--app-muted);
        line-height: 1.45;
    }

    @@media (max-width: 920px) {
        .home-hero__pattern {
            display: none;
        }

        .home-hero__copy {
            max-width: none;
        }
    }

    @@media (max-width: 600px) {
        .home-hero__actions {
            flex-direction: column;
        }

        .home-hero__actions .mud-button-root {
            width: 100%;
        }
    }
</style>
