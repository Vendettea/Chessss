@page "/player/{Id}"
@rendermode InteractiveServer
@using Chessss.Components.Common
@using Chessss.Services

@inject PlayerProfileService PlayerProfiles

<PageTitle>UltraChess - Игрок</PageTitle>

<div class="page-shell player-profile-page">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Success" />
    }
    else if (_profile is null)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Игрок не найден.</MudAlert>
    }
    else
    {
        <MudStack Spacing="3">

            <MudPaper Elevation="0" Class="public-profile-card player-profile-hero">
                <div class="player-profile-hero__head">
                    <UserAvatar AvatarUrl="@_profile.AvatarUrl"
                                DisplayName="@_profile.Nickname"
                                AvatarSize="Size.Large" />

                    <div class="player-profile-hero__copy">
                        <MudText Typo="Typo.h4">@_profile.Nickname</MudText>
                        <MudText Typo="Typo.body2" Class="player-muted">В рейтинге: @(_profile.Rank?.ToString() ?? "пока нет")</MudText>
                    </div>
                </div>

                <div class="responsive-grid player-profile-stats">
                    <div class="stats-card profile-stat">
                        <span>Рейтинг Elo</span>
                        <strong>@_profile.EloRating</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Место в рейтинге</span>
                        <strong>@(_profile.Rank?.ToString() ?? "—")</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Макс. уровень ИИ</span>
                        <strong>@_profile.MaxAIDifficultyText</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Сыграно партий</span>
                        <strong>@_profile.GamesPlayed</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Победы</span>
                        <strong>@_profile.Wins</strong>
                    </div>
                   <div class="stats-card profile-stat">
                        <span>Поражения</span>
                        <strong>@_profile.Losses</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Ничьи</span>
                        <strong>@_profile.Draws</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Win rate</span>
                        <strong>@_profile.WinRateText</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Средняя точность</span>
                        <strong>@_profile.AverageAccuracyText</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Дата регистрации</span>
                        <strong>@_profile.RegisteredAt.ToLocalTime().ToString("dd.MM.yyyy")</strong>
                    </div>
                </div>
            </MudPaper>

            <MudButton Href="/leaderboard"
                       Variant="Variant.Outlined"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Leaderboard">
                К таблице лидеров
            </MudButton>
        </MudStack>
    }
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    private PlayerProfileSummary? _profile;
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _profile = await PlayerProfiles.GetProfileAsync(Id ?? string.Empty, includeEmail: false);
        _loading = false;
    }
}
