@page "/player/{Id}"
@rendermode InteractiveServer
@using Chessss.Services

@inject PlayerProfileService PlayerProfiles

<PageTitle>UltraChess - Игрок</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Success" />
    }
    else if (_profile is null)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
            Игрок не найден.
        </MudAlert>
    }
    else
    {
        <MudStack Spacing="3">
            <div>
                <MudText Typo="Typo.h3">@_profile.Nickname</MudText>
                <MudText Typo="Typo.body2" Class="player-muted">Публичный профиль игрока</MudText>
            </div>

            <MudPaper Elevation="3" Class="pa-5 player-panel">
                <div class="player-stat-grid">
                    <span>EloRating</span><strong>@_profile.EloRating</strong>
                    <span>GamesPlayed</span><strong>@_profile.GamesPlayed</strong>
                    <span>Wins</span><strong>@_profile.Wins</strong>
                    <span>Losses</span><strong>@_profile.Losses</strong>
                    <span>Draws</span><strong>@_profile.Draws</strong>
                    <span>WinRate</span><strong>@_profile.WinRateText</strong>
                    <span>Место</span><strong>@(_profile.Rank?.ToString() ?? "нет в лидерборде")</strong>
                </div>
            </MudPaper>

            <MudButton Href="/leaderboard"
                       Variant="Variant.Outlined"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Leaderboard">
                К лидерборду
            </MudButton>
        </MudStack>
    }
</MudContainer>

<style>
    .player-panel {
        border-radius: 12px;
    }

    .player-muted {
        opacity: 0.75;
    }

    .player-stat-grid {
        display: grid;
        grid-template-columns: minmax(120px, 1fr) minmax(0, 2fr);
        gap: 0.9rem 1rem;
        align-items: center;
    }

    .player-stat-grid span {
        opacity: 0.7;
    }

    .player-stat-grid strong {
        min-width: 0;
        overflow-wrap: anywhere;
        font-variant-numeric: tabular-nums;
    }
</style>

@code {
    [Parameter]
    public string? Id { get; set; }

    private PlayerProfileSummary? _profile;
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _profile = await PlayerProfiles.GetProfileAsync(Id ?? string.Empty, includeEmail: false);
        _loading = false;
    }
}
