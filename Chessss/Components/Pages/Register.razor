@page "/regis"
@using MudBlazor
@using Chessss.Models
@using Chessss.Services
@using Microsoft.AspNetCore.Identity
@using System.ComponentModel.DataAnnotations

@inject UserManager<ApplicationUser> UserManager
@inject PlayerProfileService PlayerProfiles
@inject NavigationManager Nav

<PageTitle>UltraChess - Registration</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="height: 80vh;">
    <MudPaper Elevation="4" Class="pa-8"
              Style="@($"width: 100%; background-color: {(IsDarkMode ? "#1e1e1e" : "#ffffff")}; color: {(IsDarkMode ? "#ffffff" : "#212121")}; border-radius: 20px; border: 1px solid {(IsDarkMode ? "#333" : "transparent")}; transition: 0.3s;")">

        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6 fw-bold">Регистрация</MudText>

        <EditForm Model="RegModel" OnValidSubmit="HandleRegister" FormName="register-form">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="RegModel.Email"
                          name="Model.Email"
                          Label="Email"
                          Variant="Variant.Filled"
                          Class="mb-4"
                          For="@(() => RegModel.Email)"
                          Required="true"
                          RequiredError="Введите Email" />

            <MudTextField @bind-Value="RegModel.Password"
                          name="Model.Password"
                          Label="Пароль"
                          Variant="Variant.Filled"
                          InputType="InputType.Password"
                          Class="mb-4"
                          For="@(() => RegModel.Password)"
                          Required="true"
                          RequiredError="Введите пароль" />

            <MudTextField @bind-Value="RegModel.ConfirmPassword"
                          name="Model.ConfirmPassword"
                          Label="Повторите пароль"
                          Variant="Variant.Filled"
                          InputType="InputType.Password"
                          For="@(() => RegModel.ConfirmPassword)"
                          Required="true"
                          RequiredError="Повторите ввод пароля" />

            @if (!string.IsNullOrEmpty(_serverError))
            {
                <MudText Color="Color.Error" Typo="Typo.caption" Class="d-block mb-4 mt-2" Align="Align.Center">@_serverError</MudText>
            }

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Success"
                       FullWidth="true"
                       Class="mt-4 py-3">
                Зарегистрироваться
            </MudButton>
        </EditForm>

        <div class="d-flex justify-center mt-4">
            <MudText Typo="Typo.body2" Class="mr-1" Style="@($"color: {(IsDarkMode ? "#aaa" : "#666")}")">Есть аккаунт?</MudText>
            <MudLink Href="/auth" Underline="Underline.Hover" Color="Color.Success" Typo="Typo.body2" Class="fw-bold">Войти</MudLink>
        </div>
    </MudPaper>
</MudContainer>

@code {
    [CascadingParameter] public bool IsDarkMode { get; set; }

    [SupplyParameterFromForm]
    public RegisterInput Model { get; set; } = new();

    private RegisterInput RegModel => Model ??= new();
    private string? _serverError;

    public class RegisterInput
    {
        [Required(ErrorMessage = "Введите Email")]
        [EmailAddress(ErrorMessage = "Введите корректный Email")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Введите пароль")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Повторите ввод пароля")]
        [Compare(nameof(Password), ErrorMessage = "Пароли не совпадают")]
        public string ConfirmPassword { get; set; } = "";
    }

    private async Task HandleRegister()
    {
        _serverError = null;
        var email = RegModel.Email.Trim();

        try
        {
            ApplicationUser newUser = new ApplicationUser
            {
                UserName = email,
                Email = email,
                Nickname = await PlayerProfiles.GenerateUniqueNicknameAsync(email),
                EloRating = 1200,
                RegisteredAt = DateTime.UtcNow
            };
            newUser.NormalizedNickname = UserProfileRules.NormalizeNickname(newUser.Nickname);

            var result = await UserManager.CreateAsync(newUser, RegModel.Password);

            if (result.Succeeded)
            {
                var roleResult = await UserManager.AddToRoleAsync(newUser, UltraChessRoles.User);

                if (!roleResult.Succeeded)
                {
                    await UserManager.DeleteAsync(newUser);
                    _serverError = string.Join(" ", roleResult.Errors.Select(ToUserFriendlyError));
                    return;
                }

                Nav.NavigateTo("/auth?registered=1", forceLoad: true);
            }
            else
            {
                _serverError = string.Join(" ", result.Errors.Select(ToUserFriendlyError));
            }
        }
        catch (Exception ex)
        {
            _serverError = "Ошибка сервера";
            Console.WriteLine(ex.Message);
        }
    }

    private static string ToUserFriendlyError(IdentityError error)
    {
        return error.Code switch
        {
            "DuplicateUserName" or "DuplicateEmail" => "Пользователь с такой почтой уже существует.",
            "PasswordTooShort" => "Пароль слишком короткий.",
            "PasswordRequiresDigit" => "Пароль должен содержать хотя бы одну цифру.",
            "PasswordRequiresLower" => "Пароль должен содержать строчную букву.",
            "PasswordRequiresUpper" => "Пароль должен содержать заглавную букву.",
            "PasswordRequiresNonAlphanumeric" => "Пароль должен содержать специальный символ.",
            _ => error.Description
        };
    }
}
