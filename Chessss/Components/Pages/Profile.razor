@page "/profile"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using Chessss.Models
@using Chessss.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity

@inject UserManager<ApplicationUser> UserManager
@inject PlayerProfileService PlayerProfiles
@inject NavigationManager Nav

<PageTitle>UltraChess - Профиль</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Success" />
    }
    else if (_profile is null)
    {
        <MudAlert Severity="Severity.Error">Не удалось загрузить профиль.</MudAlert>
    }
    else
    {
        <MudStack Spacing="3">
            <div>
                <MudText Typo="Typo.h3" style="text-align: center;">Мой профиль</MudText>
            </div>

            @if (Saved == "1")
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Filled">Никнейм сохранен.</MudAlert>
            }

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_error</MudAlert>
            }

            <MudGrid Spacing="3">
                <MudItem xs="12" md="5">
                    <MudPaper Elevation="3" Class="pa-5 profile-panel">
                        <MudText Typo="Typo.h5" Class="mb-4">Настройки</MudText>

                        <EditForm Model="_editModel" OnValidSubmit="SaveNicknameAsync">
                            <DataAnnotationsValidator />

                            <MudTextField @bind-Value="_editModel.Nickname"
                                          Label="Nickname"
                                          Variant="Variant.Outlined"
                                          For="@(() => _editModel.Nickname)"
                                          Immediate="true"
                                          Class="mb-3" />

                            <MudText Typo="Typo.caption" Class="profile-muted d-block mb-4">
                                3-20 символов: латинские буквы, цифры, _ и -
                            </MudText>

                            <MudButton ButtonType="ButtonType.Submit"
                                       Variant="Variant.Filled"
                                       Color="Color.Success"
                                       FullWidth="true">
                                Сохранить
                            </MudButton>
                        </EditForm>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="7">
                    <MudPaper Elevation="3" Class="pa-5 profile-panel">
                        <MudText Typo="Typo.h5" Class="mb-4">Статистика</MudText>
                        <div class="profile-stat-grid">
                            <span>Nickname</span><strong>@_profile.Nickname</strong>
                            <span>Email</span><strong>@_profile.Email</strong>
                            <span>EloRating</span><strong>@_profile.EloRating</strong>
                            <span>GamesPlayed</span><strong>@_profile.GamesPlayed</strong>
                            <span>Wins</span><strong>@_profile.Wins</strong>
                            <span>Losses</span><strong>@_profile.Losses</strong>
                            <span>Draws</span><strong>@_profile.Draws</strong>
                            <span>WinRate</span><strong>@_profile.WinRateText</strong>
                            <span>RegisteredAt</span><strong>@_profile.RegisteredAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</strong>
                            <span>Место</span><strong>@(_profile.Rank?.ToString() ?? "нет в лидерборде")</strong>
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudStack>
    }
</MudContainer>

<style>
    .profile-panel {
        border-radius: 12px;
    }

    .profile-muted {
        opacity: 0.75;
    }

    .profile-stat-grid {
        display: grid;
        grid-template-columns: minmax(120px, 1fr) minmax(0, 2fr);
        gap: 0.9rem 1rem;
        align-items: center;
    }

    .profile-stat-grid span {
        opacity: 0.7;
    }

    .profile-stat-grid strong {
        min-width: 0;
        overflow-wrap: anywhere;
        font-variant-numeric: tabular-nums;
    }
</style>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    [SupplyParameterFromQuery]
    public string? Saved { get; set; }

    private ApplicationUser? _currentUser;
    private PlayerProfileSummary? _profile;
    private ProfileEditModel _editModel = new();
    private string? _error;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask is null)
        {
            Nav.NavigateTo("/auth", forceLoad: true);
            return;
        }

        var authState = await AuthenticationStateTask;

        if (authState.User.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/auth", forceLoad: true);
            return;
        }

        _currentUser = await UserManager.GetUserAsync(authState.User);

        if (_currentUser is null)
        {
            Nav.NavigateTo("/auth", forceLoad: true);
            return;
        }

        _profile = await PlayerProfiles.GetProfileAsync(_currentUser.Id, includeEmail: true);
        _editModel.Nickname = UserProfileRules.GetDisplayName(_currentUser.Nickname, _currentUser.Email);
        _loading = false;
    }

    private async Task SaveNicknameAsync()
    {
        _error = UserProfileRules.ValidateNickname(_editModel.Nickname);

        if (_error is not null || _currentUser is null)
        {
            return;
        }

        var nickname = _editModel.Nickname.Trim();

        if (!await PlayerProfiles.IsNicknameAvailableAsync(nickname, _currentUser.Id))
        {
            _error = "Этот никнейм уже занят.";
            return;
        }

        _currentUser.Nickname = nickname;
        _currentUser.NormalizedNickname = UserProfileRules.NormalizeNickname(nickname);

        var result = await UserManager.UpdateAsync(_currentUser);

        if (!result.Succeeded)
        {
            _error = string.Join(" ", result.Errors.Select(e => e.Description));
            return;
        }

        Nav.NavigateTo("/profile?saved=1", forceLoad: true);
    }

    private sealed class ProfileEditModel
    {
        [Required(ErrorMessage = "Никнейм обязателен.")]
        [StringLength(UserProfileRules.MaxNicknameLength, MinimumLength = UserProfileRules.MinNicknameLength, ErrorMessage = "Никнейм должен быть длиной от 3 до 20 символов.")]
        [RegularExpression("^[A-Za-z0-9_-]+$", ErrorMessage = "Никнейм может содержать только латинские буквы, цифры, _ и -.")]
        public string Nickname { get; set; } = string.Empty;
    }
}
