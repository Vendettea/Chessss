@page "/profile"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using Chessss.Components.Common
@using Chessss.Models
@using Chessss.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Identity

@inject UserManager<ApplicationUser> UserManager
@inject PlayerProfileService PlayerProfiles
@inject UserAvatarService AvatarService
@inject UserProfileChangeNotifier ProfileNotifier
@inject NavigationManager Nav

<PageTitle>UltraChess - Профиль</PageTitle>

<div class="page-shell profile-page">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Success" />
    }
    else if (_profile is null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">Не удалось загрузить профиль.</MudAlert>
    }
    else
    {
        <MudStack Spacing="3">
            <div class="profile-page__heading">
    <MudText Typo="Typo.h3">Профиль</MudText>
</div>

            @if (!string.IsNullOrWhiteSpace(_statusMessage))
            {
                <MudAlert Severity="@_statusSeverity" Variant="Variant.Outlined">@_statusMessage</MudAlert>
            }

            <MudPaper Elevation="0" Class="profile-card profile-hero-card">
                <div class="profile-hero-card__head">
    <UserAvatar AvatarUrl="@_profile.AvatarUrl"
                DisplayName="@_profile.Nickname"
                AvatarSize="Size.Large"
                Class="profile-hero-card__avatar" />

    <div class="profile-hero-card__copy">
        <MudText Typo="Typo.h4">@_profile.Nickname</MudText>
        <MudText Typo="Typo.body2" Class="profile-muted">@_profile.Email</MudText>
    </div>

    <form action="Account/Logout"
          method="post"
          class="profile-logout-form">

        <AntiforgeryToken />
        <input type="hidden" name="ReturnUrl" value="/" />

        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Error">
            Выйти
        </MudButton>

    </form>
</div>

                <div class="responsive-grid profile-stats-grid">
                    <div class="stats-card profile-stat">
                        <span>Рейтинг Elo</span>
                        <strong>@_profile.EloRating</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Место в рейтинге</span>
                        <strong>@(_profile.Rank?.ToString() ?? "—")</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Макс. уровень ИИ</span>
                        <strong>@_profile.MaxAIDifficultyText</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Сыграно партий</span>
                        <strong>@_profile.GamesPlayed</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Победы</span>
                        <strong>@_profile.Wins</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Поражения</span>
                        <strong>@_profile.Losses</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Ничьи</span>
                        <strong>@_profile.Draws</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Win rate</span>
                        <strong>@_profile.WinRateText</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Средняя точность</span>
                        <strong>@_profile.AverageAccuracyText</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Партии в архиве</span>
                        <strong>@_profile.ArchivedGamesCount</strong>
                    </div>
                    <div class="stats-card profile-stat">
                        <span>Дата регистрации</span>
                        <strong>@_profile.RegisteredAt.ToLocalTime().ToString("dd.MM.yyyy")</strong>
                    </div>
                </div>
            </MudPaper>

            <MudPaper Elevation="0" Class="form-panel profile-settings-card">
                <MudText Typo="Typo.h5">Настройки профиля</MudText>
                <MudText Typo="Typo.body2" Class="profile-muted">
                    Ник обновляется сразу после сохранения. Аватар поддерживает jpg, jpeg, png и webp до 5 МБ.
                </MudText>

                <div class="profile-settings-grid">

    <div>
        <EditForm Model="_editModel" OnValidSubmit="SaveNicknameAsync">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="_editModel.Nickname"
                          Label="Никнейм"
                          Variant="Variant.Outlined"
                          For="@(() => _editModel.Nickname)"
                          Immediate="true"
                          Class="mb-2" />

            <MudText Typo="Typo.caption"
                     Class="profile-muted d-block mb-4">
                3-20 символов: латинские буквы, цифры, _ и -
            </MudText>

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Success"
                       Disabled="@_busy"
                       FullWidth="true">
                Сохранить никнейм
            </MudButton>
        </EditForm>
    </div>

    <div>
        <MudText Typo="Typo.h6">Аватар</MudText>

        <div class="profile-upload-row">
            <div class="profile-upload-stack">
                <InputFile OnChange="HandleAvatarSelectedAsync"
                           accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
                           class="profile-upload-input" />

                <MudText Typo="Typo.caption"
                         Class="profile-meta-line">
                    Только изображения. Старый файл удаляется автоматически после замены.
                </MudText>
            </div>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Error"
                       Disabled="@(_busy || string.IsNullOrWhiteSpace(_currentUser?.AvatarUrl))"
                       OnClick="DeleteAvatarAsync">
                Удалить аватар
            </MudButton>
        </div>
    </div>

</div>
            </MudPaper>
        </MudStack>

        
    }
</div>

<style>
    html {
  overflow: hidden;
}
</style>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private ApplicationUser? _currentUser;
    private PlayerProfileSummary? _profile;
    private readonly ProfileEditModel _editModel = new();
    private bool _loading = true;
    private bool _busy;
    private string? _statusMessage;
    private Severity _statusSeverity = Severity.Success;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        if (AuthenticationStateTask is null)
        {
            Nav.NavigateTo("/auth", forceLoad: true);
            return;
        }

        var authState = await AuthenticationStateTask;

        if (authState.User.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/auth", forceLoad: true);
            return;
        }

        _currentUser = await UserManager.GetUserAsync(authState.User);

        if (_currentUser is null)
        {
            Nav.NavigateTo("/auth", forceLoad: true);
            return;
        }

        _profile = await PlayerProfiles.GetProfileAsync(_currentUser.Id, includeEmail: true);
        _editModel.Nickname = UserProfileRules.GetDisplayName(_currentUser.Nickname, _currentUser.Email);
        _loading = false;
    }

    private async Task SaveNicknameAsync()
    {
        if (_currentUser is null)
        {
            return;
        }

        _busy = true;
        _statusMessage = UserProfileRules.ValidateNickname(_editModel.Nickname);

        if (_statusMessage is not null)
        {
            _statusSeverity = Severity.Error;
            _busy = false;
            return;
        }

        var nickname = _editModel.Nickname.Trim();

        if (!await PlayerProfiles.IsNicknameAvailableAsync(nickname, _currentUser.Id))
        {
            _statusSeverity = Severity.Error;
            _statusMessage = "Этот никнейм уже занят.";
            _busy = false;
            return;
        }

        _currentUser.Nickname = nickname;
        _currentUser.NormalizedNickname = UserProfileRules.NormalizeNickname(nickname);

        var result = await UserManager.UpdateAsync(_currentUser);

        if (!result.Succeeded)
        {
            _statusSeverity = Severity.Error;
            _statusMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            _busy = false;
            return;
        }

        _profile = await PlayerProfiles.GetProfileAsync(_currentUser.Id, includeEmail: true);
        await ProfileNotifier.NotifyAsync(_currentUser.Id);
        _statusSeverity = Severity.Success;
        _statusMessage = "Никнейм сохранён.";
        _busy = false;
    }

    private async Task HandleAvatarSelectedAsync(InputFileChangeEventArgs args)
    {
        if (_currentUser is null)
        {
            return;
        }

        var file = args.File;

        if (file is null)
        {
            return;
        }

        _busy = true;

        var previousAvatarUrl = _currentUser.AvatarUrl;
        var uploadResult = await AvatarService.SaveAvatarAsync(_currentUser.Id, file);

        if (!uploadResult.Success || string.IsNullOrWhiteSpace(uploadResult.AvatarUrl))
        {
            _statusSeverity = Severity.Error;
            _statusMessage = uploadResult.ErrorMessage ?? "Не удалось загрузить аватар.";
            _busy = false;
            return;
        }

        _currentUser.AvatarUrl = uploadResult.AvatarUrl;
        var updateResult = await UserManager.UpdateAsync(_currentUser);

        if (!updateResult.Succeeded)
        {
            await AvatarService.DeleteAvatarAsync(uploadResult.AvatarUrl);
            _currentUser.AvatarUrl = previousAvatarUrl;
            _statusSeverity = Severity.Error;
            _statusMessage = string.Join(" ", updateResult.Errors.Select(e => e.Description));
            _busy = false;
            return;
        }

        await AvatarService.DeleteAvatarAsync(previousAvatarUrl);
        _profile = await PlayerProfiles.GetProfileAsync(_currentUser.Id, includeEmail: true);
        await ProfileNotifier.NotifyAsync(_currentUser.Id);
        _statusSeverity = Severity.Success;
        _statusMessage = "Аватар обновлён.";
        _busy = false;
    }

    private async Task DeleteAvatarAsync()
    {
        if (_currentUser is null || string.IsNullOrWhiteSpace(_currentUser.AvatarUrl))
        {
            return;
        }

        _busy = true;
        var previousAvatarUrl = _currentUser.AvatarUrl;
        _currentUser.AvatarUrl = null;

        var updateResult = await UserManager.UpdateAsync(_currentUser);

        if (!updateResult.Succeeded)
        {
            _currentUser.AvatarUrl = previousAvatarUrl;
            _statusSeverity = Severity.Error;
            _statusMessage = string.Join(" ", updateResult.Errors.Select(e => e.Description));
            _busy = false;
            return;
        }

        await AvatarService.DeleteAvatarAsync(previousAvatarUrl);
        _profile = await PlayerProfiles.GetProfileAsync(_currentUser.Id, includeEmail: true);
        await ProfileNotifier.NotifyAsync(_currentUser.Id);
        _statusSeverity = Severity.Success;
        _statusMessage = "Аватар удалён.";
        _busy = false;
    }

    private sealed class ProfileEditModel
    {
        [Required(ErrorMessage = "Никнейм обязателен.")]
        [StringLength(UserProfileRules.MaxNicknameLength, MinimumLength = UserProfileRules.MinNicknameLength, ErrorMessage = "Никнейм должен быть длиной от 3 до 20 символов.")]
        [RegularExpression("^[A-Za-z0-9_-]+$", ErrorMessage = "Никнейм может содержать только латинские буквы, цифры, _ и -.")]
        public string Nickname { get; set; } = string.Empty;
    }
}
