@page "/playwithai"
@rendermode InteractiveServer
@using System.Security.Claims
@using Chessss.Components.Common
@using Chessss.Models
@using Chessss.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject UserProfileChangeNotifier ProfileNotifier
@inject Chessss.Services.UserDifficultyService UserDifficultyService
@inject Chessss.Services.GameResultService GameResults
@inject Chessss.Services.UserGameService UserGames
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>UltraChess - Игра с ИИ</PageTitle>

<div class="play-ai-page page-shell">
    <div class="play-ai-stage">
        <div class="play-ai-layout chess-layout">
            <section class="play-ai-board-area" aria-label="Шахматная доска">
                <div class="play-ai-board-column">
                    <div class="play-ai-player-strip play-ai-player-strip-top">
                        <MudAvatar Color="Color.Default" Variant="Variant.Outlined" Size="Size.Medium" Class="play-ai-avatar">
                            <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Medium" />
                        </MudAvatar>

                        <div class="play-ai-player-copy">
                            <div class="play-ai-player-name">Бот</div>
                            <div class="play-ai-player-subtitle">Уровень @GetDisplayedDifficulty()</div>
                        </div>
                    </div>

                    <div class="play-ai-board-shell chess-board-panel">
                        <div id="chessBoard" class="play-ai-board"></div>

                        @if (_showPromotionDialog)
                        {
                            <div class="play-ai-promotion-overlay">
                                <div class="play-ai-promotion-dialog">
                                    <h3 class="play-ai-promotion-title">Выберите фигуру</h3>
                                    @{ var colorPrefix = _playerColor == "black" ? "b" : "w"; }
                                    <div class="play-ai-promotion-grid">
                                        <div class="promotion-piece" @onclick='() => OnPromotionPieceSelected("q")'>
                                            <img src="/img/chesspieces/wikipedia/@(colorPrefix)Q.png" alt="Ферзь" title="Ферзь" />
                                        </div>
                                        <div class="promotion-piece" @onclick='() => OnPromotionPieceSelected("r")'>
                                            <img src="/img/chesspieces/wikipedia/@(colorPrefix)R.png" alt="Ладья" title="Ладья" />
                                        </div>
                                        <div class="promotion-piece" @onclick='() => OnPromotionPieceSelected("b")'>
                                            <img src="/img/chesspieces/wikipedia/@(colorPrefix)B.png" alt="Слон" title="Слон" />
                                        </div>
                                        <div class="promotion-piece" @onclick='() => OnPromotionPieceSelected("n")'>
                                            <img src="/img/chesspieces/wikipedia/@(colorPrefix)N.png" alt="Конь" title="Конь" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="play-ai-board-footer">
                        <div class="play-ai-player-strip play-ai-player-strip-bottom">
                            <UserAvatar AvatarUrl="@_currentUserAvatarUrl"
                                        DisplayName="@_currentUserDisplayName"
                                        AvatarSize="Size.Medium"
                                        Class="play-ai-avatar" />

                            <div class="play-ai-player-copy">
                                <div class="play-ai-player-name">@_currentUserDisplayName</div>
                                <div class="play-ai-player-subtitle">Игрок</div>
                            </div>
                        </div>

                        <div class="play-ai-timer" aria-live="polite">
                            <span class="play-ai-timer-label">Время</span>
                            <span class="play-ai-timer-value">@_elapsedTimeText</span>
                        </div>
                    </div>
                </div>
            </section>

            <aside class="play-ai-side-panel chess-side-panel" aria-label="Панель партии">
                @if (IsSetupState)
                {
                    <div class="play-ai-panel-content play-ai-start-panel">
                        <div class="play-ai-panel-head">
                            <MudText Typo="Typo.h5">Новая партия</MudText>
                            <MudText Typo="Typo.body2" Class="play-ai-muted">
                                Выберите уровень бота и сторону, затем начните игру.
                            </MudText>
                        </div>

                        <MudSelect T="int"
                                   Label="Сложность"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   @bind-Value="_selectedDifficulty">
                            @foreach (var option in DifficultyOptions)
                            {
                                <MudSelectItem T="int" Value="@option.Level">
                                    Уровень @option.Level — @option.Name
                                </MudSelectItem>
                            }
                        </MudSelect>

                        <div class="play-ai-difficulty-card">
                            <MudText Typo="Typo.subtitle2">@GetDifficultyLabel(_selectedDifficulty)</MudText>
                            <MudText Typo="Typo.body2">@GetDifficultyDescription(_selectedDifficulty)</MudText>
                        </div>

                        <div class="play-ai-difficulty-card">
                        <MudText Typo="Typo.subtitle2">Движок</MudText>
                        <MudText Typo="Typo.body2">Stockfish 18 Lite</MudText>
                        </div>

                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                            @_statusText
                        </MudAlert>

                        <div class="play-ai-control-group">
                            <MudText Typo="Typo.subtitle2">Сторона</MudText>

                            <div class="play-ai-segmented" role="radiogroup" aria-label="Выбор стороны">
                                <button type="button"
                                        class="@GetSideButtonClass(SideChoice.White)"
                                        aria-checked="@(_selectedSide == SideChoice.White)"
                                        role="radio"
                                        @onclick="@(() => SelectSide(SideChoice.White))">
                                    Белые
                                </button>
                                <button type="button"
                                        class="@GetSideButtonClass(SideChoice.Random)"
                                        aria-checked="@(_selectedSide == SideChoice.Random)"
                                        role="radio"
                                        @onclick="@(() => SelectSide(SideChoice.Random))">
                                    Случайно
                                </button>
                                <button type="button"
                                        class="@GetSideButtonClass(SideChoice.Black)"
                                        aria-checked="@(_selectedSide == SideChoice.Black)"
                                        role="radio"
                                        @onclick="@(() => SelectSide(SideChoice.Black))">
                                    Чёрные
                                </button>
                            </div>

                            <MudText Typo="Typo.caption" Class="play-ai-muted">
                                @GetSelectedSideHint()
                            </MudText>
                        </div>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   FullWidth="true"
                                   Size="Size.Large"
                                   Disabled="@(!_boardReady)"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   OnClick="StartGameAsync">
                            Играть
                        </MudButton>
                    </div>
                }
                else
                {
                    <div class="play-ai-panel-content play-ai-game-panel">
                        <div class="play-ai-status-block">
                            <MudAlert Severity="@_statusSeverity" Variant="Variant.Filled" NoIcon="true" Class="play-ai-status-alert">
                                <div class="play-ai-status-title">@_statusText</div>
                            </MudAlert>
                        </div>

                        <section class="play-ai-section play-ai-history-section">
                            <div class="play-ai-section-head">
                                <MudText Typo="Typo.subtitle1">Ходы партии</MudText>
                                <MudText Typo="Typo.caption" Class="play-ai-muted">@GetMoveCountText()</MudText>
                            </div>

                            @if (_moveRows.Count == 0)
                            {
                                <div class="play-ai-empty-history">Ходы появятся после первого сделанного хода.</div>
                            }
                            else
                            {
                                <div class="play-ai-move-table" @ref="_moveListViewport">
                                    <div class="play-ai-move-row play-ai-move-header">
                                        <span>#</span>
                                        <span>Белые</span>
                                        <span>Чёрные</span>
                                    </div>

                                    @foreach (var move in _moveRows)
                                    {
                                        <div class="@GetMoveRowClass(move)">
                                            <span>@move.Number.</span>
                                            <span>@move.White</span>
                                            <span>@move.Black</span>
                                        </div>
                                    }
                                </div>
                            }
                        </section>

                        @if (IsFinishedState)
                        {
                            <section class="play-ai-section play-ai-pgn-section">
                                <div class="play-ai-section-head">
                                    <MudText Typo="Typo.subtitle1">PGN</MudText>

                                    <MudTooltip Text="Скопировать PGN">
                                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                       Size="Size.Small"
                                                       Color="Color.Primary"
                                                       Disabled="@(string.IsNullOrWhiteSpace(_currentPgn))"
                                                       OnClick="CopyPgnAsync" />
                                    </MudTooltip>
                                </div>

                                <textarea class="play-ai-pgn" readonly>@GetPgnDisplayText()</textarea>
                            </section>
                        }

                        <div class="play-ai-actions">
                            <MudTooltip Text="Заново">
                                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                               Color="Color.Primary"
                                               Size="Size.Large"
                                               OnClick="ResetToSetupAsync" />
                            </MudTooltip>

                            <MudTooltip Text="Сдаться">
                                <MudIconButton Icon="@Icons.Material.Filled.Flag"
                                               Color="Color.Error"
                                               Size="Size.Large"
                                               Disabled="@_gameOver"
                                               OnClick="ConfirmResignAsync" />
                            </MudTooltip>
                        </div>
                    </div>
                }
            </aside>
        </div>
    </div>
</div>

<style>
    .play-ai-promotion-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        background: rgba(0, 0, 0, 0.6);
        z-index: 100;
        border-radius: 22px;
        backdrop-filter: blur(2px);
    }

    .play-ai-promotion-dialog {
        background: var(--mud-palette-surface);
        padding: 1.5rem;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
        text-align: center;
        border: 1px solid var(--play-ai-border);
    }

    .play-ai-promotion-title {
        margin: 0 0 1rem;
        font-size: 1.2rem;
        font-weight: 600;
    }

    .play-ai-promotion-grid {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .promotion-piece {
        width: 64px;
        height: 64px;
        cursor: pointer;
        border-radius: 8px;
        transition: background-color 0.2s, transform 0.1s;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .promotion-piece:hover {
        background-color: var(--play-ai-soft-strong);
        transform: scale(1.05);
    }
    
    .promotion-piece img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .play-ai-page {
        --play-ai-border: var(--app-border);
        --play-ai-soft: color-mix(in srgb, var(--app-surface-2) 74%, transparent);
        --play-ai-soft-strong: color-mix(in srgb, var(--app-surface-2) 88%, transparent);
        --play-ai-muted-color: var(--app-muted);
        --play-ai-selected-square: rgba(244, 211, 94, 0.38);
        --play-ai-move-dot: color-mix(in srgb, var(--app-accent-2) 62%, white);
        --play-ai-panel-height: clamp(520px, calc(100dvh - 126px), 760px);
        padding: 0.5rem 0 1.25rem;
    }

    .play-ai-stage {
        max-width: 1280px;
        margin: 0 auto;
    }

    .play-ai-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) clamp(300px, 28vw, 344px);
        justify-content: center;
        gap: clamp(0.85rem, 1.5vw, 1.15rem);
        align-items: start;
        min-width: 0;
    }

    .play-ai-board-area {
        min-width: 0;
    }

    .play-ai-board-column {
        width: min(100%, 760px, max(320px, calc(100dvh - 14rem)));
        margin: 0 auto;
    }

    .play-ai-player-strip,
    .play-ai-board-shell,
    .play-ai-board-footer,
    .play-ai-side-panel {
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0)),
            color-mix(in srgb, var(--mud-palette-surface) 88%, black);
        border: 1px solid var(--play-ai-border);
        box-shadow: 0 18px 36px rgba(0, 0, 0, 0.22);
    }

    .play-ai-player-strip {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        padding: 0.85rem 1rem;
        border-radius: 18px;
    }

    .play-ai-player-strip-top {
        margin-bottom: 0.85rem;
    }

    .play-ai-avatar {
        flex-shrink: 0;
        background: rgba(255, 255, 255, 0.04);
    }

    .play-ai-player-copy {
        min-width: 0;
    }

    .play-ai-player-name {
        font-size: 1rem;
        font-weight: 700;
        line-height: 1.2;
    }

    .play-ai-player-subtitle {
        margin-top: 0.15rem;
        font-size: 0.88rem;
        color: var(--play-ai-muted-color);
    }

    .play-ai-board-shell {
        position: relative;
        padding: 0.75rem;
        border-radius: 22px;
    }

    .play-ai-board {
        width: 100%;
        max-width: 760px;
        margin: 0 auto;
    }

    .play-ai-board .board-b72b1 {
        border: 1px solid rgba(0, 0, 0, 0.35);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 24px 48px rgba(0, 0, 0, 0.28);
    }

    .play-ai-board .square-55d63 {
        position: relative;
        cursor: pointer;
    }

    .play-ai-board .square-55d63.play-ai-square-selected {
        box-shadow: inset 0 0 0 999px var(--play-ai-selected-square);
    }

    .play-ai-board .square-55d63.play-ai-square-target::after {
        content: "";
        position: absolute;
        inset: auto;
        top: 50%;
        left: 50%;
        width: 26%;
        height: 26%;
        transform: translate(-50%, -50%);
        border-radius: 50%;
        background: var(--play-ai-move-dot);
        pointer-events: none;
    }

    .play-ai-board .square-55d63.play-ai-square-target.play-ai-square-occupied::after {
        width: 72%;
        height: 72%;
        background: transparent;
        border: 5px solid var(--play-ai-move-dot);
    }

    .play-ai-board-footer {
        margin-top: 0.85rem;
        padding: 0.85rem 1rem;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .play-ai-player-strip-bottom {
        margin: 0;
        padding: 0;
        border: 0;
        background: transparent;
        box-shadow: none;
        min-width: 0;
    }

    .play-ai-timer {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.15rem;
        min-width: 84px;
        padding: 0.55rem 0.75rem;
        border-radius: 14px;
        background: var(--play-ai-soft);
    }

    .play-ai-timer-label {
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--play-ai-muted-color);
    }

    .play-ai-timer-value {
        font-size: 1.12rem;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
    }

    .play-ai-side-panel {
        display: flex;
        min-width: 0;
        border-radius: 22px;
        overflow: hidden;
        min-height: 0;
        height: var(--play-ai-panel-height);
        max-height: var(--play-ai-panel-height);
        position: sticky;
        top: 1rem;
    }

    .play-ai-panel-content {
        flex: 1 1 auto;
        width: 100%;
        height: 100%;
        min-height: 0;
        max-height: 100%;
        padding: 1.1rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        overflow: hidden;
    }

    .play-ai-panel-head {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .play-ai-start-panel {
        justify-content: center;
        overflow-y: auto;
    }

    .play-ai-muted {
        color: var(--play-ai-muted-color);
    }

    .play-ai-difficulty-card {
        padding: 0.9rem 1rem;
        border: 1px solid var(--play-ai-border);
        border-radius: 16px;
        background: var(--play-ai-soft);
    }

    .play-ai-control-group {
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
    }

    .play-ai-segmented {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.4rem;
        padding: 0.35rem;
        border-radius: 16px;
        border: 1px solid var(--play-ai-border);
        background: var(--play-ai-soft);
    }

    .play-ai-side-option {
        min-height: 46px;
        border: 0;
        border-radius: 12px;
        background: transparent;
        color: inherit;
        font: inherit;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
    }

    .play-ai-side-option:hover {
        background: rgba(255, 255, 255, 0.08);
    }

    .play-ai-side-option.is-selected {
        color: var(--mud-palette-success-text);
        background: var(--mud-palette-success);
        box-shadow: 0 10px 22px rgba(46, 125, 50, 0.3);
    }

    .play-ai-game-panel {
        overflow: hidden;
        min-height: 0;
    }

    .play-ai-status-block {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .play-ai-status-alert {
        border-radius: 16px;
    }

    .play-ai-status-title {
        font-weight: 700;
        line-height: 1.35;
    }

    .play-ai-status-meta {
        margin-top: 0.3rem;
        font-size: 0.9rem;
        opacity: 0.88;
    }

    .play-ai-game-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
    }

    .play-ai-game-meta span {
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        background: var(--play-ai-soft);
        border: 1px solid var(--play-ai-border);
        font-size: 0.84rem;
    }

    .play-ai-section {
        min-height: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .play-ai-history-section {
        flex: 1 1 0;
        overflow: hidden;
        min-height: 0;
    }

    .play-ai-section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        min-height: 32px;
    }

    .play-ai-empty-history {
        padding: 1rem;
        border-radius: 16px;
        border: 1px dashed rgba(255, 255, 255, 0.18);
        color: var(--play-ai-muted-color);
        background: rgba(255, 255, 255, 0.03);
    }

    .play-ai-move-table {
        flex: 1 1 auto;
        overflow-y: auto;
        padding-right: 0.2rem;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        min-height: 0;
        max-height: 100%;
        overscroll-behavior: contain;
    }

    .play-ai-move-row {
        display: grid;
        grid-template-columns: 46px minmax(0, 1fr) minmax(0, 1fr);
        gap: 0.6rem;
        align-items: center;
        min-height: 40px;
        padding: 0.55rem 0.7rem;
        border-radius: 14px;
        background: var(--play-ai-soft);
        border: 1px solid transparent;
        font-variant-numeric: tabular-nums;
    }

    .play-ai-move-row span {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .play-ai-move-header {
        position: sticky;
        top: 0;
        z-index: 1;
        font-weight: 700;
        background: color-mix(in srgb, var(--mud-palette-primary) 16%, var(--mud-palette-surface));
        backdrop-filter: blur(8px);
    }

    .play-ai-move-row.is-last {
        border-color: color-mix(in srgb, var(--mud-palette-success) 46%, transparent);
        background: color-mix(in srgb, var(--mud-palette-success) 12%, transparent);
    }

    .play-ai-pgn-section {
        flex: 0 0 auto;
    }

    .play-ai-pgn {
        width: 100%;
        min-height: 132px;
        max-height: 180px;
        resize: vertical;
        padding: 0.8rem 0.9rem;
        border-radius: 16px;
        border: 1px solid var(--play-ai-border);
        background: rgba(255, 255, 255, 0.04);
        color: inherit;
        font-family: ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", monospace;
        font-size: 0.88rem;
        line-height: 1.45;
        white-space: pre-wrap;
    }

    .play-ai-actions {
        flex-shrink: 0;
        display: flex;
        justify-content: flex-end;
        gap: 0.35rem;
        padding-top: 0.75rem;
        border-top: 1px solid var(--play-ai-border);
    }

    @@media (max-width: 1360px) {
        .play-ai-page {
            --play-ai-panel-height: clamp(520px, calc(100dvh - 120px), 720px);
        }

        .play-ai-stage {
            max-width: 1100px;
        }

        .play-ai-board-column,
        .play-ai-board {
            max-width: 720px;
        }
    }

    @@media (max-width: 1180px) {
        .play-ai-layout {
            grid-template-columns: minmax(0, 1fr);
            gap: 1rem;
        }

        .play-ai-side-panel {
            position: static;
            height: auto;
            max-height: none;
        }

        .play-ai-panel-content {
            height: auto;
            max-height: none;
            min-height: auto;
        }

        .play-ai-move-table {
            max-height: min(42vh, 360px);
        }
    }

    @@media (max-width: 720px) {
        .play-ai-page {
            padding: 0.35rem 0 1.2rem;
        }

        .play-ai-board-shell {
            padding: 0.55rem;
            border-radius: 20px;
        }

        .play-ai-board-footer {
            flex-direction: column;
            align-items: stretch;
        }

        .play-ai-timer {
            align-items: flex-start;
        }

        .play-ai-panel-content {
            padding: 0.9rem;
        }

        .play-ai-pgn {
            min-height: 120px;
            max-height: 160px;
        }

        .play-ai-segmented {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private const int DefaultDifficulty = 6;
    private const string StockfishEngineKey = "stockfish18Lite";
    private const string StockfishEngineLabel = "Stockfish 18 Lite";

    private static readonly IReadOnlyList<DifficultyOption> DifficultyOptions = new[]
