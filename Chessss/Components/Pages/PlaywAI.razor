    private async Task LoadCurrentUserDisplayAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var principal = authState.User;

            if (principal.Identity?.IsAuthenticated != true)
            {
                _currentUserId = null;
                _currentUserDisplayName = "Гость";
                _currentUserAvatarUrl = null;
                return;
            }

            var user = await UserManager.GetUserAsync(principal);
            var email = user?.Email ?? principal.Identity?.Name;
            _currentUserId = user?.Id;
            _currentUserDisplayName = UserProfileRules.GetDisplayName(user?.Nickname, email);
            _currentUserAvatarUrl = user?.AvatarUrl;
        }
        catch
        {
            _currentUserId = null;
            _currentUserDisplayName = "Гость";
            _currentUserAvatarUrl = null;
        }
    }

    private async Task HandleProfileChangedAsync(string userId)
    {
        if (string.IsNullOrWhiteSpace(_currentUserId) || !string.Equals(_currentUserId, userId, StringComparison.Ordinal))
        {
            return;
        }

        await InvokeAsync(async () =>
        {
            await LoadCurrentUserDisplayAsync();
            StateHasChanged();
        });
    }

    private async Task<int> LoadStoredDifficultyAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrWhiteSpace(userId))
            {
                return DefaultDifficulty;
            }

            var storedDifficulty = await UserDifficultyService.GetDifficultyAsync(userId);
            return NormalizeDifficulty(storedDifficulty ?? DefaultDifficulty);
        }
        catch
        {
            return DefaultDifficulty;
        }
    }

    private async Task SaveStoredDifficultyAsync(int difficulty)
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrWhiteSpace(userId))
            {
                return;
            }

            await UserDifficultyService.SetDifficultyAsync(userId, difficulty);
        }
        catch
        {
        }
    }

    private async Task TryRecordAiGameResultAsync(string resultCode, string finalFen, int moveCount)
    {
        var terminalSignature = BuildTerminalSignature(resultCode, finalFen, moveCount);

        if (_resultRecordedForCurrentGame || _resultRecordingInProgress || _recordedTerminalSignature == terminalSignature)
        {
            return;
        }

        _resultRecordingInProgress = true;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrWhiteSpace(userId))
            {
                _resultSaveSeverity = Severity.Info;
                _resultSaveText = "Партия завершена. Войдите в аккаунт, чтобы следующие результаты попадали в статистику.";
                return;
            }

            var statsSaved = await GameResults.RecordAiGameResultAsync(userId, resultCode);
            var gameSaved = await TrySaveUserGameAsync(userId, resultCode, terminalSignature);

            if (statsSaved && gameSaved)
            {
                if (string.Equals(resultCode, "win", StringComparison.OrdinalIgnoreCase))
                {
                    await UpdateMaxAIDifficultyBeatenAsync(userId, _activeDifficulty);
                }

                _resultRecordedForCurrentGame = true;
                _recordedTerminalSignature = terminalSignature;
                _resultSaveSeverity = Severity.Success;
                _resultSaveText = "Результат партии сохранён в профиль и добавлен в мои партии.";
                return;
            }

            if (statsSaved)
            {
                _resultSaveSeverity = Severity.Warning;
                _resultSaveText = "Результат партии сохранён в профиль, но запись в мои партии не создалась.";
                return;
            }

            if (gameSaved)
            {
                _resultSaveSeverity = Severity.Warning;
                _resultSaveText = "Запись в мои партии создана, но результат не был записан в статистику.";
                return;
            }

            _resultSaveSeverity = Severity.Warning;
            _resultSaveText = "Партия завершена, но сохранить результат не удалось.";
        }
        catch
        {
            _resultSaveSeverity = Severity.Warning;
            _resultSaveText = "Партия завершена, но результат не удалось сохранить.";
        }
        finally
        {
            _resultRecordingInProgress = false;
        }
    }

    private async Task<bool> TrySaveUserGameAsync(string userId, string resultCode, string terminalSignature)
    {
        if (string.IsNullOrWhiteSpace(userId) || string.IsNullOrWhiteSpace(_currentPgn))
        {
            return false;
        }

        var isPlayerBlack = string.Equals(_playerColor, "black", StringComparison.OrdinalIgnoreCase);
        var result = ResolveStoredGameResult(resultCode, isPlayerBlack);

        var userGame = new UserGame
        {
            UserId = userId,
            PlayedAt = _gameFinishedAtUtc?.UtcDateTime ?? DateTime.UtcNow,
            WhitePlayer = isPlayerBlack ? "Bot" : _currentUserDisplayName,
            BlackPlayer = isPlayerBlack ? _currentUserDisplayName : "Bot",
            Result = result,
            MoveCount = _moveCount,
            DurationMinutes = CalculateDurationMinutes(),
                Source = "UltraChess",
                ExternalId = $"{terminalSignature}|{_gameStartedAtUtc?.UtcDateTime.Ticks ?? 0L}",
                PlayedAsWhite = !isPlayerBlack,
                IsAnalyzed = false,
            WhiteAccuracy = null,
            BlackAccuracy = null,
            PgnContent = _currentPgn
        };

        return await UserGames.SaveUserGameAsync(userGame);
    }

    private int CalculateDurationMinutes()
    {
        if (_gameStartedAtUtc is null)
        {
            return 0;
        }

        var finishedAt = _gameFinishedAtUtc ?? DateTimeOffset.UtcNow;
        var elapsed = finishedAt - _gameStartedAtUtc.Value;

        if (elapsed <= TimeSpan.Zero)
        {
            return 1;
        }

        return Math.Max(1, (int)Math.Ceiling(elapsed.TotalMinutes));
    }

    private static string ResolveStoredGameResult(string resultCode, bool isPlayerBlack)
    {
        return resultCode.Trim().ToLowerInvariant() switch
        {
            "win" => isPlayerBlack ? "0-1" : "1-0",
            "loss" => isPlayerBlack ? "1-0" : "0-1",
            "draw" => "1/2-1/2",
            _ => "*"
        };
    }

    private async Task UpdateMaxAIDifficultyBeatenAsync(string userId, int difficulty)
    {
        try
        {
            var user = await UserManager.FindByIdAsync(userId);

            if (user is null)
            {
                return;
            }

            if (user.MaxAIDifficultyBeaten.GetValueOrDefault() >= difficulty)
            {
                return;
            }

            user.MaxAIDifficultyBeaten = difficulty;
            var updateResult = await UserManager.UpdateAsync(user);

            if (updateResult.Succeeded)
            {
                await ProfileNotifier.NotifyAsync(user.Id);
            }
        }
        catch
        {
        }
    }

