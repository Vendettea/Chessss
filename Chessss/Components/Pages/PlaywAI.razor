@page "/playwithai"
@rendermode InteractiveServer
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>UltraChess - Игра с ИИ</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudGrid>
        @* Левая колонка: Шахматная доска *@
        <MudItem xs="12" md="7" lg="6">
            <MudPaper Elevation="4" Class="pa-2" Style="background-color: #2b2b2b;">
                <div id="chessBoard" style="width: 100%"></div>
            </MudPaper>
        </MudItem>

        @* Правая колонка: Статус и управление *@
        <MudItem xs="12" md="5" lg="4">
            <MudStack Spacing="4">
                <MudCard Elevation="4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h5">Противник: Stockfish</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body1">Статус партии:</MudText>
                        <MudAlert Severity="Severity.Normal" Variant="Variant.Filled" Class="mt-2" NoIcon="true">
                            <code style="color: white; font-size: 0.75rem;">@_currentFen</code>
                        </MudAlert>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Error"
                                   FullWidth="true"
                                   OnClick="RestartGame">
                            Начать заново
                        </MudButton>
                    </MudCardActions>
                </MudCard>

                <MudAlert Severity="Severity.Info">
                    Сложность: Глубина 12
                </MudAlert>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private string _currentFen = "start";
    private DotNetObjectReference<PlaywAI>? _objRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            // Инициализируем доску через наш JS-бридж
            await JS.InvokeVoidAsync("chessBridge.initGame", _objRef, "chessBoard");
        }
    }

    [JSInvokable]
    public void OnMovePerformed(string fen)
    {
        _currentFen = fen;
        StateHasChanged();
    }

    private async Task RestartGame()
    {
        _currentFen = "start";
        await JS.InvokeVoidAsync("chessBridge.reset");
    }

    public void Dispose()
    {
        _objRef?.Dispose();
    }
}