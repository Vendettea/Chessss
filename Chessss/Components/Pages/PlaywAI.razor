    private void StartGameClock()
    {
        ResetGameClock();

        _gameStartedAtUtc = DateTimeOffset.UtcNow;
        _gameFinishedAtUtc = null;
        UpdateElapsedTimeText();

        _gameClockTimer = new Timer(_ =>
        {
            if (_disposed || _gameStartedAtUtc is null || _gameOver)
            {
                return;
            }

            _ = InvokeAsync(() =>
            {
                UpdateElapsedTimeText();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void CompleteGameClock()
    {
        if (_gameStartedAtUtc is null)
        {
            return;
        }

        _gameFinishedAtUtc ??= DateTimeOffset.UtcNow;
        UpdateElapsedTimeText();
        _gameClockTimer?.Dispose();
        _gameClockTimer = null;
    }

    private void ResetGameClock()
    {
        _gameClockTimer?.Dispose();
        _gameClockTimer = null;
        _gameStartedAtUtc = null;
        _gameFinishedAtUtc = null;
        _elapsedTimeText = "00:00";
    }

    private void UpdateElapsedTimeText()
    {
        if (_gameStartedAtUtc is null)
        {
            _elapsedTimeText = "00:00";
            return;
        }

        var elapsed = (_gameFinishedAtUtc ?? DateTimeOffset.UtcNow) - _gameStartedAtUtc.Value;

        if (elapsed < TimeSpan.Zero)
        {
            elapsed = TimeSpan.Zero;
        }

        _elapsedTimeText = elapsed.TotalHours >= 1
            ? elapsed.ToString(@"hh\:mm\:ss")
            : elapsed.ToString(@"mm\:ss");
    }

    private static string BuildTerminalSignature(string resultCode, string finalFen, int moveCount) => $"{resultCode}|{moveCount}|{finalFen}";

    private void RebuildMoveRows(IReadOnlyList<string>? moves)
    {
        _moveRows.Clear();

        if (moves is null || moves.Count == 0)
        {
            return;
        }

        for (var i = 0; i < moves.Count; i += 2)
        {
            _moveRows.Add(new MoveRow
            {
                Number = (i / 2) + 1,
                White = moves[i],
                Black = i + 1 < moves.Count ? moves[i + 1] : "...",
                IsLast = i + 2 >= moves.Count
            });
        }
    }

    private static int NormalizeDifficulty(int difficulty) => Math.Clamp(difficulty, 1, 20);

    private static Severity ResolveStatusSeverity(string status, bool gameStarted, bool gameOver, string resultCode)
    {
        if (!gameStarted)
        {
            return Severity.Info;
        }

        if (gameOver)
        {
            return resultCode switch
            {
                "win" => Severity.Success,
                "draw" => Severity.Info,
                _ => Severity.Error
            };
        }

        if (status.Contains("ИИ", StringComparison.OrdinalIgnoreCase)
            && status.Contains("ход", StringComparison.OrdinalIgnoreCase))
        {
            return Severity.Warning;
        }

        return Severity.Success;
    }

    private static DifficultyOption GetDifficultyOption(int difficulty)
    {
        var normalized = NormalizeDifficulty(difficulty);
        return DifficultyOptions.FirstOrDefault(x => x.Level == normalized)
            ?? DifficultyOptions[DefaultDifficulty - 1];
    }

    private static string GetDifficultyLabel(int difficulty)
    {
        var option = GetDifficultyOption(difficulty);
        return $"Уровень {option.Level}: {option.Name}";
    }

    private static string GetDifficultyDescription(int difficulty)
    {
        var option = GetDifficultyOption(difficulty);
        var timeText = option.MoveTimeMs >= 1000
            ? $"{option.MoveTimeMs / 1000.0:0.#} сек."
            : $"{option.MoveTimeMs} мс";

        return $"{option.Description} Диапазон силы: {option.EloMin}–{option.EloMax} Elo. Время на ход: около {timeText}";
    }

    private static string FormatCount(int count, string one, string few, string many)
    {
        var abs = Math.Abs(count) % 100;
        var lastDigit = abs % 10;

        if (abs is >= 11 and <= 14)
        {
            return $"{count} {many}";
        }

        return lastDigit switch
        {
            1 => $"{count} {one}",
            2 or 3 or 4 => $"{count} {few}",
            _ => $"{count} {many}"
        };
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        ProfileNotifier.Changed -= HandleProfileChangedAsync;
        _gameClockTimer?.Dispose();
        _gameClockTimer = null;

        if (_objRef is null)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("chessBridge.destroy");
        }
        catch (JSDisconnectedException)
        {
        }

        _objRef.Dispose();
    }


    private enum SideChoice
    {
        White,
        Random,
        Black
    }

    private sealed record DifficultyOption(
        int Level,
        string Name,
        int EloMin,
        int EloMax,
        int EngineElo,
        int MoveTimeMs,
        string Description);

    private sealed class MoveRow
    {
        public int Number { get; init; }
        public string White { get; init; } = string.Empty;
        public string Black { get; init; } = string.Empty;
        public bool IsLast { get; init; }
    }
}
