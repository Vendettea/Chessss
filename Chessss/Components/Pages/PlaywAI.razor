@page "/playwithai"
@rendermode InteractiveServer
@using System.Security.Claims
@using Chessss.Models
@using Chessss.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject Chessss.Services.UserDifficultyService UserDifficultyService
@inject Chessss.Services.GameResultService GameResults
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>UltraChess - Игра с ИИ</PageTitle>

<div class="play-ai-page">
    <div class="play-ai-stage">
        <div class="play-ai-layout">
            <section class="play-ai-board-area" aria-label="Шахматная доска">
                <div class="play-ai-board-column">
                    <div class="play-ai-player-strip play-ai-player-strip-top">
                        <MudAvatar Color="Color.Default" Variant="Variant.Outlined" Size="Size.Medium" Class="play-ai-avatar">
                            <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Medium" />
                        </MudAvatar>

                        <div class="play-ai-player-copy">
                            <div class="play-ai-player-name">Бот</div>
                            <div class="play-ai-player-subtitle">Уровень @GetDisplayedDifficulty()</div>
                        </div>
                    </div>

                    <div class="play-ai-board-shell" style="position: relative;">
                        <div id="chessBoard" class="play-ai-board"></div>

                        @if (_showPromotionDialog)
                        {
                            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: rgba(0, 0, 0, 0.6); z-index: 100; border-radius: 22px; backdrop-filter: blur(2px);">
                                <div style="background: var(--mud-palette-surface); padding: 1.5rem; border-radius: 16px; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5); text-align: center; border: 1px solid var(--play-ai-border);">
                                    <h3 style="margin-top: 0; margin-bottom: 1rem; font-weight: 600; font-size: 1.2rem;">Выберите фигуру</h3>
                                    @{ var colorPrefix = _playerColor == "black" ? "b" : "w"; }
                                    <div style="display: flex; gap: 12px; justify-content: center;">
                                        <div class="promotion-piece" @onclick='() => OnPromotionPieceSelected("q")'>
                                            <img src="/img/chesspieces/wikipedia/@(colorPrefix)Q.png" alt="Ферзь" title="Ферзь" />
                                        </div>
                                        <div class="promotion-piece" @onclick='() => OnPromotionPieceSelected("r")'>
                                            <img src="/img/chesspieces/wikipedia/@(colorPrefix)R.png" alt="Ладья" title="Ладья" />
                                        </div>
                                        <div class="promotion-piece" @onclick='() => OnPromotionPieceSelected("b")'>
                                            <img src="/img/chesspieces/wikipedia/@(colorPrefix)B.png" alt="Слон" title="Слон" />
                                        </div>
                                        <div class="promotion-piece" @onclick='() => OnPromotionPieceSelected("n")'>
                                            <img src="/img/chesspieces/wikipedia/@(colorPrefix)N.png" alt="Конь" title="Конь" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="play-ai-board-footer">
                        <div class="play-ai-player-strip play-ai-player-strip-bottom">
                            <MudAvatar Color="Color.Default" Variant="Variant.Outlined" Size="Size.Medium" Class="play-ai-avatar">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Medium" />
                            </MudAvatar>

                            <div class="play-ai-player-copy">
                                <div class="play-ai-player-name">@_currentUserDisplayName</div>
                                <div class="play-ai-player-subtitle">Игрок</div>
                            </div>
                        </div>

                        <div class="play-ai-timer" aria-live="polite">
                            <span class="play-ai-timer-label">Время</span>
                            <span class="play-ai-timer-value">@_elapsedTimeText</span>
                        </div>
                    </div>
                </div>
            </section>

            <aside class="play-ai-side-panel" aria-label="Панель партии">
                @if (IsSetupState)
                {
                    <div class="play-ai-panel-content play-ai-start-panel">
                        <div class="play-ai-panel-head">
                            <MudText Typo="Typo.h5">Новая партия</MudText>
                            <MudText Typo="Typo.body2" Class="play-ai-muted">
                                Выберите силу бота и сторону, затем начните игру.
                            </MudText>
                        </div>

                        <MudSelect T="int"
                                   Label="Сложность"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   @bind-Value="_selectedDifficulty">
                            @foreach (var level in DifficultyLevels)
                            {
                                <MudSelectItem T="int" Value="@level">Уровень @level</MudSelectItem>
                            }
                        </MudSelect>

                        <div class="play-ai-difficulty-card">
                            <MudText Typo="Typo.subtitle2">@GetDifficultyLabel(_selectedDifficulty)</MudText>
                            <MudText Typo="Typo.body2">@GetDifficultyDescription(_selectedDifficulty)</MudText>
                        </div>

                        <div class="play-ai-control-group">
                            <MudText Typo="Typo.subtitle2">Сторона</MudText>

                            <div class="play-ai-segmented" role="radiogroup" aria-label="Выбор стороны">
                                <button type="button"
                                        class="@GetSideButtonClass(SideChoice.White)"
                                        aria-checked="@(_selectedSide == SideChoice.White)"
                                        role="radio"
                                        @onclick="@(() => SelectSide(SideChoice.White))">
                                    Белые
                                </button>
                                <button type="button"
                                        class="@GetSideButtonClass(SideChoice.Random)"
                                        aria-checked="@(_selectedSide == SideChoice.Random)"
                                        role="radio"
                                        @onclick="@(() => SelectSide(SideChoice.Random))">
                                    Случайно
                                </button>
                                <button type="button"
                                        class="@GetSideButtonClass(SideChoice.Black)"
                                        aria-checked="@(_selectedSide == SideChoice.Black)"
                                        role="radio"
                                        @onclick="@(() => SelectSide(SideChoice.Black))">
                                    Чёрные
                                </button>
                            </div>

                            <MudText Typo="Typo.caption" Class="play-ai-muted">
                                @GetSelectedSideHint()
                            </MudText>
                        </div>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   FullWidth="true"
                                   Size="Size.Large"
                                   Disabled="@(!_boardReady)"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   OnClick="StartGameAsync">
                            Играть
                        </MudButton>
                    </div>
                }
                else
                {
                    <div class="play-ai-panel-content play-ai-game-panel">
                        <div class="play-ai-status-block">
                            <MudAlert Severity="@_statusSeverity" Variant="Variant.Filled" NoIcon="true" Class="play-ai-status-alert">
                                <div class="play-ai-status-title">@_statusText</div>
                            </MudAlert>
                        </div>

                        <section class="play-ai-section play-ai-history-section">
                            <div class="play-ai-section-head">
                                <MudText Typo="Typo.subtitle1">Ходы партии</MudText>
                                <MudText Typo="Typo.caption" Class="play-ai-muted">@GetMoveCountText()</MudText>
                            </div>

                            @if (_moveRows.Count == 0)
                            {
                                <div class="play-ai-empty-history">Ходы появятся после первого сделанного хода.</div>
                            }
                            else
                            {
                                <div class="play-ai-move-table" @ref="_moveListViewport">
                                    <div class="play-ai-move-row play-ai-move-header">
                                        <span>#</span>
                                        <span>Белые</span>
                                        <span>Чёрные</span>
                                    </div>

                                    @foreach (var move in _moveRows)
                                    {
                                        <div class="@GetMoveRowClass(move)">
                                            <span>@move.Number.</span>
                                            <span>@move.White</span>
                                            <span>@move.Black</span>
                                        </div>
                                    }
                                </div>
                            }
                        </section>

                        @if (IsFinishedState)
                        {
                            <section class="play-ai-section play-ai-pgn-section">
                                <div class="play-ai-section-head">
                                    <MudText Typo="Typo.subtitle1">PGN</MudText>

                                    <MudTooltip Text="Скопировать PGN">
                                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                       Size="Size.Small"
                                                       Color="Color.Primary"
                                                       Disabled="@(string.IsNullOrWhiteSpace(_currentPgn))"
                                                       OnClick="CopyPgnAsync" />
                                    </MudTooltip>
                                </div>

                                <textarea class="play-ai-pgn" readonly>@GetPgnDisplayText()</textarea>
                            </section>
                        }

                        <div class="play-ai-actions">
                            <MudTooltip Text="Заново">
                                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                               Color="Color.Primary"
                                               Size="Size.Large"
                                               OnClick="ResetToSetupAsync" />
                            </MudTooltip>

                            <MudTooltip Text="Сдаться">
                                <MudIconButton Icon="@Icons.Material.Filled.Flag"
                                               Color="Color.Error"
                                               Size="Size.Large"
                                               Disabled="@_gameOver"
                                               OnClick="ConfirmResignAsync" />
                            </MudTooltip>
                        </div>
                    </div>
                }
            </aside>
        </div>
    </div>
</div>

<style>
    .promotion-piece {
        width: 64px;
        height: 64px;
        cursor: pointer;
        border-radius: 8px;
        transition: background-color 0.2s, transform 0.1s;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .promotion-piece:hover {
        background-color: var(--play-ai-soft-strong);
        transform: scale(1.05);
    }
    
    .promotion-piece img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .play-ai-page {
        --play-ai-border: rgba(255, 255, 255, 0.08);
        --play-ai-soft: rgba(255, 255, 255, 0.05);
        --play-ai-soft-strong: rgba(255, 255, 255, 0.08);
        --play-ai-muted-color: rgba(255, 255, 255, 0.68);
        --play-ai-selected-square: rgba(244, 211, 94, 0.38);
        --play-ai-move-dot: rgba(255, 255, 255, 0.42);
        --play-ai-panel-height: clamp(560px, calc(100dvh - 122px), 780px);
        padding: 0.85rem 1rem 1.5rem;
    }

    .play-ai-stage {
        max-width: 1160px;
        margin: 0 auto;
    }

    .play-ai-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) clamp(300px, 28vw, 344px);
        justify-content: center;
        gap: clamp(0.85rem, 1.5vw, 1.15rem);
        align-items: start;
        min-width: 0;
    }

    .play-ai-board-area {
        min-width: 0;
    }

    .play-ai-board-column {
        width: min(100%, 760px);
        margin: 0 auto;
    }

    .play-ai-player-strip,
    .play-ai-board-shell,
    .play-ai-board-footer,
    .play-ai-side-panel {
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0)),
            color-mix(in srgb, var(--mud-palette-surface) 88%, black);
        border: 1px solid var(--play-ai-border);
        box-shadow: 0 18px 36px rgba(0, 0, 0, 0.22);
    }

    .play-ai-player-strip {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        padding: 0.85rem 1rem;
        border-radius: 18px;
    }

    .play-ai-player-strip-top {
        margin-bottom: 0.85rem;
    }

    .play-ai-avatar {
        flex-shrink: 0;
        background: rgba(255, 255, 255, 0.04);
    }

    .play-ai-player-copy {
        min-width: 0;
    }

    .play-ai-player-name {
        font-size: 1rem;
        font-weight: 700;
        line-height: 1.2;
    }

    .play-ai-player-subtitle {
        margin-top: 0.15rem;
        font-size: 0.88rem;
        color: var(--play-ai-muted-color);
    }

    .play-ai-board-shell {
        padding: 0.75rem;
        border-radius: 22px;
    }

    .play-ai-board {
        width: 100%;
        max-width: 760px;
        margin: 0 auto;
    }

    .play-ai-board .board-b72b1 {
        border: 1px solid rgba(0, 0, 0, 0.35);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 24px 48px rgba(0, 0, 0, 0.28);
    }

    .play-ai-board .square-55d63 {
        position: relative;
        cursor: pointer;
    }

    .play-ai-board .square-55d63.play-ai-square-selected {
        box-shadow: inset 0 0 0 999px var(--play-ai-selected-square);
    }

    .play-ai-board .square-55d63.play-ai-square-target::after {
        content: "";
        position: absolute;
        inset: auto;
        top: 50%;
        left: 50%;
        width: 26%;
        height: 26%;
        transform: translate(-50%, -50%);
        border-radius: 50%;
        background: var(--play-ai-move-dot);
        pointer-events: none;
    }

    .play-ai-board .square-55d63.play-ai-square-target.play-ai-square-occupied::after {
        width: 72%;
        height: 72%;
        background: transparent;
        border: 5px solid var(--play-ai-move-dot);
    }

    .play-ai-board-footer {
        margin-top: 0.85rem;
        padding: 0.85rem 1rem;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .play-ai-player-strip-bottom {
        margin: 0;
        padding: 0;
        border: 0;
        background: transparent;
        box-shadow: none;
        min-width: 0;
    }

    .play-ai-timer {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.15rem;
        min-width: 84px;
        padding: 0.55rem 0.75rem;
        border-radius: 14px;
        background: var(--play-ai-soft);
    }

    .play-ai-timer-label {
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--play-ai-muted-color);
    }

    .play-ai-timer-value {
        font-size: 1.12rem;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
    }

    .play-ai-side-panel {
        display: flex;
        min-width: 0;
        border-radius: 22px;
        overflow: hidden;
        min-height: 0;
        height: var(--play-ai-panel-height);
        max-height: var(--play-ai-panel-height);
        position: sticky;
        top: 0.85rem;
    }

    .play-ai-panel-content {
        flex: 1 1 auto;
        width: 100%;
        height: 100%;
        min-height: 0;
        max-height: 100%;
        padding: 1.1rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        overflow: hidden;
    }

    .play-ai-panel-head {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .play-ai-start-panel {
        justify-content: center;
        overflow-y: auto;
    }

    .play-ai-muted {
        color: var(--play-ai-muted-color);
    }

    .play-ai-difficulty-card {
        padding: 0.9rem 1rem;
        border: 1px solid var(--play-ai-border);
        border-radius: 16px;
        background: var(--play-ai-soft);
    }

    .play-ai-control-group {
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
    }

    .play-ai-segmented {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.4rem;
        padding: 0.35rem;
        border-radius: 16px;
        border: 1px solid var(--play-ai-border);
        background: var(--play-ai-soft);
    }

    .play-ai-side-option {
        min-height: 46px;
        border: 0;
        border-radius: 12px;
        background: transparent;
        color: inherit;
        font: inherit;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
    }

    .play-ai-side-option:hover {
        background: rgba(255, 255, 255, 0.08);
    }

    .play-ai-side-option.is-selected {
        color: var(--mud-palette-success-text);
        background: var(--mud-palette-success);
        box-shadow: 0 10px 22px rgba(46, 125, 50, 0.3);
    }

    .play-ai-game-panel {
        overflow: hidden;
        min-height: 0;
    }

    .play-ai-status-block {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .play-ai-status-alert {
        border-radius: 16px;
    }

    .play-ai-status-title {
        font-weight: 700;
        line-height: 1.35;
    }

    .play-ai-status-meta {
        margin-top: 0.3rem;
        font-size: 0.9rem;
        opacity: 0.88;
    }

    .play-ai-game-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
    }

    .play-ai-game-meta span {
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        background: var(--play-ai-soft);
        border: 1px solid var(--play-ai-border);
        font-size: 0.84rem;
    }

    .play-ai-section {
        min-height: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .play-ai-history-section {
        flex: 1 1 0;
        overflow: hidden;
        min-height: 0;
    }

    .play-ai-section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        min-height: 32px;
    }

    .play-ai-empty-history {
        padding: 1rem;
        border-radius: 16px;
        border: 1px dashed rgba(255, 255, 255, 0.18);
        color: var(--play-ai-muted-color);
        background: rgba(255, 255, 255, 0.03);
    }

    .play-ai-move-table {
        flex: 1 1 auto;
        overflow-y: auto;
        padding-right: 0.2rem;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        min-height: 0;
        max-height: 100%;
        overscroll-behavior: contain;
    }

    .play-ai-move-row {
        display: grid;
        grid-template-columns: 46px minmax(0, 1fr) minmax(0, 1fr);
        gap: 0.6rem;
        align-items: center;
        min-height: 40px;
        padding: 0.55rem 0.7rem;
        border-radius: 14px;
        background: var(--play-ai-soft);
        border: 1px solid transparent;
        font-variant-numeric: tabular-nums;
    }

    .play-ai-move-row span {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .play-ai-move-header {
        position: sticky;
        top: 0;
        z-index: 1;
        font-weight: 700;
        background: color-mix(in srgb, var(--mud-palette-primary) 16%, var(--mud-palette-surface));
        backdrop-filter: blur(8px);
    }

    .play-ai-move-row.is-last {
        border-color: color-mix(in srgb, var(--mud-palette-success) 46%, transparent);
        background: color-mix(in srgb, var(--mud-palette-success) 12%, transparent);
    }

    .play-ai-pgn-section {
        flex: 0 0 auto;
    }

    .play-ai-pgn {
        width: 100%;
        min-height: 132px;
        max-height: 180px;
        resize: vertical;
        padding: 0.8rem 0.9rem;
        border-radius: 16px;
        border: 1px solid var(--play-ai-border);
        background: rgba(255, 255, 255, 0.04);
        color: inherit;
        font-family: ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", monospace;
        font-size: 0.88rem;
        line-height: 1.45;
        white-space: pre-wrap;
    }

    .play-ai-actions {
        flex-shrink: 0;
        display: flex;
        justify-content: flex-end;
        gap: 0.35rem;
        padding-top: 0.75rem;
        border-top: 1px solid var(--play-ai-border);
    }

    @@media (max-width: 1360px) {
        .play-ai-page {
            --play-ai-panel-height: clamp(540px, calc(100dvh - 116px), 740px);
        }

        .play-ai-stage {
            max-width: 1100px;
        }

        .play-ai-board-column,
        .play-ai-board {
            max-width: 720px;
        }
    }

    @@media (max-width: 1180px) {
        .play-ai-layout {
            grid-template-columns: minmax(0, 1fr);
            gap: 1rem;
        }

        .play-ai-side-panel {
            position: static;
            height: auto;
            max-height: none;
        }

        .play-ai-panel-content {
            height: auto;
            max-height: none;
            min-height: auto;
        }

        .play-ai-move-table {
            max-height: min(42vh, 360px);
        }
    }

    @@media (max-width: 720px) {
        .play-ai-page {
            padding: 0.85rem 0.85rem 1.5rem;
        }

        .play-ai-board-shell {
            padding: 0.55rem;
            border-radius: 20px;
        }

        .play-ai-board-footer {
            flex-direction: column;
            align-items: stretch;
        }

        .play-ai-timer {
            align-items: flex-start;
        }

        .play-ai-panel-content {
            padding: 0.9rem;
        }

        .play-ai-pgn {
            min-height: 120px;
            max-height: 160px;
        }

        .play-ai-segmented {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private const int DefaultDifficulty = 6;

    private readonly IReadOnlyList<int> DifficultyLevels = Enumerable.Range(1, 20).ToArray();
    private readonly List<MoveRow> _moveRows = new();

    private DotNetObjectReference<PlaywAI>? _objRef;
    private ElementReference _moveListViewport;
    private Timer? _gameClockTimer;

    private string _currentFen = "start";
    private string _currentPgn = string.Empty;
    private string _currentUserDisplayName = "Гость";
    private string _elapsedTimeText = "00:00";
    private string _statusText = "Выберите сложность, сторону и нажмите «Играть».";
    private string? _resultSaveText;
    private string? _playerColor;
    private string? _recordedTerminalSignature;
    private DateTimeOffset? _gameStartedAtUtc;
    private DateTimeOffset? _gameFinishedAtUtc;
    private Severity _statusSeverity = Severity.Info;
    private Severity _resultSaveSeverity = Severity.Info;
    private int _selectedDifficulty = DefaultDifficulty;
    private int _activeDifficulty = DefaultDifficulty;
    private int _moveCount;
    private SideChoice _selectedSide = SideChoice.Random;
    private bool _boardReady;
    private bool _gameStarted;
    private bool _gameOver;
    private bool _resultRecordedForCurrentGame;
    private bool _scrollMovesToBottom;
    private bool _disposed;

    private bool _showPromotionDialog;
    private string _promotionSource = string.Empty;
    private string _promotionTarget = string.Empty;

    private bool IsSetupState => !_gameStarted;
    private bool IsFinishedState => _gameStarted && _gameOver;

    protected override async Task OnInitializedAsync()
    {
        _selectedDifficulty = await LoadStoredDifficultyAsync();
        _activeDifficulty = _selectedDifficulty;
        await LoadCurrentUserDisplayAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("chessBridge.initGame", _objRef, "chessBoard", _selectedDifficulty);
            _boardReady = true;
        }

        if (_scrollMovesToBottom && _moveCount > 0)
        {
            _scrollMovesToBottom = false;
            await JS.InvokeVoidAsync("chessBridge.scrollElementToBottom", _moveListViewport);
        }
    }

    [JSInvokable]
    public async Task OnGameStateChanged(
        string fen,
        string status,
        string[] moves,
        bool gameStarted,
        bool gameOver,
        string resultCode,
        string pgn,
        string playerColor)
    {
        _currentFen = fen;
        _currentPgn = pgn ?? string.Empty;
        _statusText = status;
        _gameStarted = gameStarted;
        _gameOver = gameOver;
        _playerColor = NormalizePlayerColor(playerColor);
        _statusSeverity = ResolveStatusSeverity(status, gameStarted, gameOver, resultCode);

        RebuildMoveRows(moves);
        _moveCount = moves?.Length ?? 0;
        _scrollMovesToBottom = _gameStarted && _moveCount > 0;

        if (gameStarted && gameOver)
        {
            CompleteGameClock();
        }

        if (gameStarted && gameOver && Chessss.Services.GameResultService.IsTerminalResultCode(resultCode))
        {
            await TryRecordAiGameResultAsync(resultCode, fen, _moveCount);
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task PromptForPromotion(string source, string target)
    {
        _promotionSource = source;
        _promotionTarget = target;
        _showPromotionDialog = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task OnPromotionPieceSelected(string piece)
    {
        _showPromotionDialog = false;
        await JS.InvokeVoidAsync("chessBridge.completePromotion", _promotionSource, _promotionTarget, piece);
    }

    private async Task StartGameAsync()
    {
        if (!_boardReady)
        {
            return;
        }

        _activeDifficulty = NormalizeDifficulty(_selectedDifficulty);
        _currentFen = "start";
        _currentPgn = string.Empty;
        _resultSaveText = null;
        _resultSaveSeverity = Severity.Info;
        _moveRows.Clear();
        _moveCount = 0;
        _gameStarted = true;
        _gameOver = false;
        _resultRecordedForCurrentGame = false;
        _recordedTerminalSignature = null;
        _scrollMovesToBottom = false;
        _statusText = "Партия запускается...";
        _statusSeverity = Severity.Info;
        _playerColor = ResolveExpectedPlayerColor(_selectedSide);

        StartGameClock();
        await SaveStoredDifficultyAsync(_activeDifficulty);
        await JS.InvokeVoidAsync("chessBridge.startNewGame", _activeDifficulty, GetRequestedSide());
    }

    private async Task ResetToSetupAsync()
    {
        ResetGameClock();

        _currentFen = "start";
        _currentPgn = string.Empty;
        _resultSaveText = null;
        _statusText = "Выберите сложность, сторону и нажмите «Играть».";
        _statusSeverity = Severity.Info;
        _resultSaveSeverity = Severity.Info;
        _moveRows.Clear();
        _moveCount = 0;
        _gameStarted = false;
        _gameOver = false;
        _playerColor = null;
        _resultRecordedForCurrentGame = false;
        _recordedTerminalSignature = null;
        _scrollMovesToBottom = false;

        if (_boardReady)
        {
            await JS.InvokeVoidAsync("chessBridge.prepareForNewGame");
        }
    }

    private async Task ConfirmResignAsync()
    {
        if (!_boardReady || !_gameStarted || _gameOver)
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", "Сдаться? Поражение будет записано в статистику партии.");

        if (!confirmed)
        {
            return;
        }

        await JS.InvokeVoidAsync("chessBridge.resignGame");
    }

    private async Task LoadCurrentUserDisplayAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var principal = authState.User;

            if (principal.Identity?.IsAuthenticated != true)
            {
                _currentUserDisplayName = "Гость";
                return;
            }

            var user = await UserManager.GetUserAsync(principal);
            var email = user?.Email ?? principal.Identity?.Name;
            _currentUserDisplayName = UserProfileRules.GetDisplayName(user?.Nickname, email);
        }
        catch
        {
            _currentUserDisplayName = "Гость";
        }
    }

    private async Task<int> LoadStoredDifficultyAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrWhiteSpace(userId))
            {
                return DefaultDifficulty;
            }

            var storedDifficulty = await UserDifficultyService.GetDifficultyAsync(userId);
            return NormalizeDifficulty(storedDifficulty ?? DefaultDifficulty);
        }
        catch
        {
            return DefaultDifficulty;
        }
    }

    private async Task SaveStoredDifficultyAsync(int difficulty)
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrWhiteSpace(userId))
            {
                return;
            }

            await UserDifficultyService.SetDifficultyAsync(userId, difficulty);
        }
        catch
        {
        }
    }

    private async Task TryRecordAiGameResultAsync(string resultCode, string finalFen, int moveCount)
    {
        var terminalSignature = BuildTerminalSignature(resultCode, finalFen, moveCount);

        if (_resultRecordedForCurrentGame || _recordedTerminalSignature == terminalSignature)
        {
            return;
        }

        _resultRecordedForCurrentGame = true;
        _recordedTerminalSignature = terminalSignature;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrWhiteSpace(userId))
            {
                _resultSaveSeverity = Severity.Info;
                _resultSaveText = "Партия завершена. Войдите в аккаунт, чтобы следующие результаты попадали в статистику.";
                return;
            }

            var saved = await GameResults.RecordAiGameResultAsync(userId, resultCode);

            if (saved)
            {
                _resultSaveSeverity = Severity.Success;
                _resultSaveText = "Результат партии сохранён в профиль.";
                return;
            }

            _resultSaveSeverity = Severity.Warning;
            _resultSaveText = "Партия завершена, но результат не был записан в статистику.";
        }
        catch
        {
            _resultSaveSeverity = Severity.Warning;
            _resultSaveText = "Партия завершена, но результат не удалось сохранить.";
        }
    }

