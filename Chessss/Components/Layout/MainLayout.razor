@inherits LayoutComponentBase
@implements IDisposable
@using Chessss.Components.Common
@using Chessss.Models
@using Chessss.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using MudBlazor
@inject UserManager<ApplicationUser> UserManager
@inject UserProfileChangeNotifier ProfileNotifier


<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<div class="app-shell @(_isMini ? "sidebar-collapsed" : "sidebar-expanded")" style="@BuildShellStyle()">
    <aside class="sidebar">
        <div class="sidebar__top">
            <button type="button" class="sidebar-brand" @onclick='() => Nav.NavigateTo("/")'>
                <span class="sidebar-brand__mark">
                    <img src="/images/logo.png" alt="UltraChess" class="sidebar-brand__logo" />
                </span>

                @if (!_isMini)
                {
                    <span class="sidebar-brand__copy">
                        <span class="sidebar-brand__title">UltraChess</span>
                    </span>
                }
            </button>

            <MudIconButton Icon="@(_isMini ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ChevronLeft)"
                           Size="Size.Small"
                           Variant="Variant.Text"
                           Color="Color.Default"
                           Class="sidebar-toggle"
                           OnClick="ToggleDrawer" />
        </div>

        <nav class="sidebar__nav">
            <MudNavMenu Class="sidebar-nav">
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Главная</MudNavLink>
                <MudNavLink Href="/playwithai" Icon="@Icons.Material.Filled.SmartToy">Играть с ИИ</MudNavLink>
                <MudNavLink Href="/analysis" Icon="@Icons.Material.Filled.Search">Анализ партии</MudNavLink>
                <MudNavLink Href="/training" Icon="@Icons.Material.Filled.School">Обучение</MudNavLink>
                <MudNavLink Href="/leaderboard" Icon="@Icons.Material.Filled.Leaderboard">Таблица лидеров</MudNavLink>
                <MudNavLink Href="/my-games" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.List">Мои партии</MudNavLink>
                <MudNavLink Href="/admin/training" Icon="@Icons.Material.Filled.AdminPanelSettings">Админка</MudNavLink>
            </MudNavMenu>
        </nav>

        <div class="sidebar__footer">
            <MudNavLink Href="/feedback" Icon="@Icons.Material.Filled.ChatBubbleOutline" Class="sidebar-feedback">Обратная связь</MudNavLink>

            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Size="Size.Medium"
                           Variant="Variant.Outlined"
                           Color="Color.Default"
                           Class="sidebar-theme-toggle"
                           OnClick="ToggleTheme" />

            @if (_isAuthenticated)
            {
                <div class="sidebar-account profile-card" @onclick='() => Nav.NavigateTo("/profile")'>
                    <UserAvatar AvatarUrl="@_currentAvatarUrl"
                                DisplayName="@_accountDisplayName"
                                AvatarSize="Size.Small"
                                Class="sidebar-account__avatar" />

                    @if (!_isMini)
                    {
                        <div class="sidebar-account__copy">
                            <span class="sidebar-account__name">@_accountDisplayName</span>
                            <span class="sidebar-account__meta">Профиль</span>
                        </div>
                    }

                   
                </div>
            }
            else
            {
                <div class="sidebar-account profile-card" @onclick='() => Nav.NavigateTo("/auth")'>
                    <MudAvatar Variant="Variant.Outlined" Size="Size.Small" Class="sidebar-account__fallback">
                        <MudIcon Icon="@Icons.Material.Filled.Login" Size="Size.Small" />
                    </MudAvatar>

                    @if (!_isMini)
                    {
                        <div class="sidebar-account__copy">
                            <span class="sidebar-account__name">Войти</span>
                            <span class="sidebar-account__meta">Авторизация</span>
                        </div>
                    }
                </div>
            }
        </div>
    </aside>

    <main class="app-main">
        <div class="page-container">
            <CascadingValue Value="_isDarkMode">
                @Body
            </CascadingValue>
        </div>
    </main>
</div>



@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    [Inject]
    private NavigationManager Nav { get; set; } = default!;

    private bool _isMini;
    private bool _isDarkMode = true;
    private bool _isAuthenticated;
    private ApplicationUser? _currentUser;
    private string _accountDisplayName = "Войти";
    private string? _currentAvatarUrl;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#2F6F5E",
            Secondary = "#B08D57",
            Tertiary = "#4E7A9A",
            Success = "#2F6F5E",
            Warning = "#C28A32",
            Background = "#F6F3EC",
            Surface = "#FFFDF8",
            DrawerBackground = "#FFFCF5",
            AppbarBackground = "#FFFDF8",
            TextPrimary = "#1F2937",
            TextSecondary = "#5F6B7A",
            LinesDefault = "rgba(71, 85, 105, 0.16)"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#7CC9B8",
            Secondary = "#D9B06A",
            Tertiary = "#7FB6E6",
            Success = "#7CC9B8",
            Warning = "#E8B967",
            Background = "#0F172A",
            Surface = "#172033",
            DrawerBackground = "#121A2B",
            AppbarBackground = "#172033",
            TextPrimary = "#ECF2FF",
            TextSecondary = "#AAB6CC",
            LinesDefault = "rgba(148, 163, 184, 0.18)"
        }
    };

    protected override void OnInitialized()
    {
        ProfileNotifier.Changed += HandleProfileChangedAsync;
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadCurrentUserAsync();
    }

    private async Task HandleProfileChangedAsync(string userId)
    {
        if (_currentUser is null || !string.Equals(_currentUser.Id, userId, StringComparison.Ordinal))
        {
            return;
        }

        await InvokeAsync(async () =>
        {
            await LoadCurrentUserAsync();
            StateHasChanged();
        });
    }

    private async Task LoadCurrentUserAsync()
    {
        if (AuthenticationStateTask is null)
        {
            SetAnonymousAccountState();
            return;
        }

        var authState = await AuthenticationStateTask;
        var principal = authState.User;

        if (principal.Identity?.IsAuthenticated != true)
        {
            SetAnonymousAccountState();
            return;
        }

        _currentUser = await UserManager.GetUserAsync(principal);

        if (_currentUser is null)
        {
            SetAnonymousAccountState();
            return;
        }

        _isAuthenticated = true;
        _accountDisplayName = GetDisplayName(_currentUser.Nickname, _currentUser.Email ?? principal.Identity?.Name);
        _currentAvatarUrl = _currentUser.AvatarUrl;
    }

    private void ToggleDrawer() => _isMini = !_isMini;

    private void ToggleTheme() => _isDarkMode = !_isDarkMode;

    private void SetAnonymousAccountState()
    {
        _isAuthenticated = false;
        _currentUser = null;
        _currentAvatarUrl = null;
        _accountDisplayName = "Войти";
    }

    private string BuildShellStyle()
    {
        if (_isDarkMode)
        {
            return "--app-bg:#0f172a;--app-surface:#172033;--app-surface-2:#1d2840;--app-text:#ecf2ff;--app-muted:#aab6cc;--app-border:rgba(148,163,184,.18);--app-accent:#d9b06a;--app-accent-2:#7cc9b8;--sidebar-bg:#121a2b;--sidebar-width:260px;--sidebar-width-mini:84px;";
        }

        return "--app-bg:#f6f3ec;--app-surface:#fffdf8;--app-surface-2:#f0ebe2;--app-text:#1f2937;--app-muted:#5f6b7a;--app-border:rgba(71,85,105,.16);--app-accent:#2f6f5e;--app-accent-2:#b08d57;--sidebar-bg:#fffcf5;--sidebar-width:260px;--sidebar-width-mini:84px;";
    }

    private static string GetDisplayName(string? nickname, string? email)
    {
        if (!string.IsNullOrWhiteSpace(nickname))
        {
            return nickname.Trim();
        }

        if (!string.IsNullOrWhiteSpace(email))
        {
            var atIndex = email.IndexOf('@');
            return atIndex > 0 ? email[..atIndex] : email;
        }

        return "Аккаунт";
    }

    public void Dispose()
    {
        ProfileNotifier.Changed -= HandleProfileChangedAsync;
    }
}
