@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Импорт PGN</MudText>
    </TitleContent>

    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.body2">
                Вставьте полный PGN с заголовками [White], [Black], [Result], [Date] и телом партии.
            </MudText>

            <MudTextField @bind-Value="_pgn"
                          Label="PGN"
                          Variant="Variant.Outlined"
                          Lines="16"
                          AutoGrow="true"
                          FullWidth="true"
                          Immediate="true" />

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                    @_error
                </MudAlert>
            }
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Отмена</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ImportAsync">
            Импортировать
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private string _pgn = string.Empty;
    private string? _error;

    private Task ImportAsync()
    {
        if (string.IsNullOrWhiteSpace(_pgn))
        {
            _error = "PGN не может быть пустым.";
            return Task.CompletedTask;
        }

        MudDialog.Close(DialogResult.Ok(_pgn.Trim()));
        return Task.CompletedTask;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
